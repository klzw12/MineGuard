# Redis模块配置 - 开发环境
mineguard:
  redis:
    enabled: true
    key-prefix: "mineguard:"
    default-expire: 3600
    lock:
      default-expire: 30
      retry-count: 3
      retry-interval: 100
    rate-limit:
      default-window: 60
      default-limit: 100
    redisson:
      enabled: true
      retry-attempts: 3
      retry-interval: 1000
      connect-timeout: 30000

