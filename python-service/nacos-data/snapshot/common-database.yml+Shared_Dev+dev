# 数据库模块配置 - 开发环境
mineguard:
  database:
    enabled: true
    druid:
      initial-size: 2
      min-idle: 2
      max-active: 10
      max-wait: 60000
      validation-query: "SELECT 1"
      test-while-idle: true
      test-on-borrow: false
      test-on-return: false
      stat-view-username: "klzw"
      stat-view-password: "1.qwklzw"
    dynamic:
      enabled: true
      primary: "master"
      slaves: ["slave"]
    datasource:
      master:
        url: "jdbc:mysql://localhost:3306/mineguard?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true"
        username: "root"
        password: "1.qwklz5"
        driverClassName: "com.mysql.cj.jdbc.Driver"
