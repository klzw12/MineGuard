		--admin-success-color: #34C759;
		--admin-warning-color: #FF9500;
		--admin-error-color: #FF3B30;
		--admin-info-color: #5AC8FA;
		
		/* 阴影 */
		--admin-shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
		--admin-shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
		--admin-shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.16);
		
		/* 圆角 */
		--admin-radius-sm: 4rpx;
		--admin-radius-md: 8rpx;
		--admin-radius-lg: 16rpx;
		--admin-radius-xl: 24rpx;
		
		/* 间距 */
		--admin-space-xs: 8rpx;
		--admin-space-sm: 16rpx;
		--admin-space-md: 24rpx;
		--admin-space-lg: 32rpx;
		--admin-space-xl: 48rpx;
		
		/* 字体大小 */
		--admin-font-xs: 20rpx;
