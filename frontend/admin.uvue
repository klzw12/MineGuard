<template>
	<view class="admin-app-container">
		<view v-if="!loginStatus" class="loading-container">
			<text class="loading-text">加载中...</text>
		</view>
	</view>
</template>

<script lang="uts">
	// #ifdef APP-ANDROID || APP-HARMONY
	let firstBackTime = 0
	// #endif
	export default {
		data() {
			return {
				loginStatus: false
			}
		},
		onLaunch() {
			console.log('Admin App Launch')
			this.checkLoginStatus()
		},
		onShow() {
			console.log('Admin App Show')
		},
		onHide() {
			console.log('Admin App Hide')
		},
		// #ifdef APP-ANDROID || APP-HARMONY
		onLastPageBackPress() {
			console.log('Admin App LastPageBackPress')
			if (firstBackTime == 0) {
				uni.showToast({
					title: '再按一次退出应用',
					position: 'bottom',
				})
				firstBackTime = Date.now()
				setTimeout(() => {
					firstBackTime = 0
				}, 2000)
			} else if (Date.now() - firstBackTime < 2000) {
				firstBackTime = Date.now()
				uni.exit()
			}
		},
		// #endif
		onExit() {
			console.log('Admin App Exit')
		},
		methods: {
			checkLoginStatus() {
				// 检查管理端登录状态
				const loginStatus = uni.getStorageSync('loginStatus')
				const userRole = uni.getStorageSync('userRole')
				
				if (loginStatus && userRole === 'admin') {
					// 已登录管理端，跳转到管理端首页
					this.loginStatus = true
					uni.switchTab({
						url: '/pages/admin/home/index'
					})
				} else {
					// 未登录或角色不正确，跳转到管理端登录页
					this.loginStatus = false
					uni.redirectTo({
						url: '/pages/admin/login/index'
					})
				}
			}
		}
	}
</script>

<style>
	/* 管理端全局样式 */
