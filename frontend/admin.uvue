	}
	
	.loading-text {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: bold;
	}
	
	/* 管理端主题变量 */
	:root {
		/* 主色调 */
		--admin-primary-color: #007AFF;
		--admin-secondary-color: #0056b3;
		--admin-accent-color: #003366;
		
		/* 背景色 */
		--admin-bg-color: #FFFFFF;
		--admin-bg-secondary: #F5F7FA;
		--admin-bg-tertiary: #E9EEF5;
		
		/* 文字色 */
		--admin-text-primary: #333333;
