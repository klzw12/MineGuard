			border-radius: 10rpx;
			cursor: pointer;
			transition: all 0.3s ease;
			
			&.active {
				background-color: rgba(0, 122, 255, 0.1);
				color: #007AFF;
				font-weight: bold;
			}
			
			&:active {
				background-color: rgba(0, 122, 255, 0.1);
			}
			
			&.logout {
				margin-top: 50rpx;
				color: #FF3B30;
				
				&:active {
					background-color: rgba(255, 59, 48, 0.1);
				}
			}
		}
		
		/* 菜单图标 */
		.sidebar-icon {
