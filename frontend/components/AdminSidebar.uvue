<template>
	<view class="admin-sidebar">
		<!-- 侧边栏头部 -->
		<view class="sidebar-header">
			<text class="sidebar-title">MineGuard</text>
			<text class="sidebar-subtitle">管理中心</text>
		</view>
		
		<!-- 导航菜单 -->
		<view class="sidebar-menu">
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/home/index' }" 
				@click="navigateTo('/pages/admin/home/index')"
			>
				<text class="sidebar-icon">🏠</text>
				<text class="sidebar-text">首页</text>
			</view>
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/vehicle/index' }" 
				@click="navigateTo('/pages/admin/vehicle/index')"
			>
				<text class="sidebar-icon">🚚</text>
				<text class="sidebar-text">车辆管理</text>
			</view>
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/driver/index' }" 
				@click="navigateTo('/pages/admin/driver/index')"
			>
				<text class="sidebar-icon">👨‍💼</text>
				<text class="sidebar-text">司机管理</text>
			</view>
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/monitor/index' }" 
				@click="navigateTo('/pages/admin/monitor/index')"
			>
				<text class="sidebar-icon">📺</text>
				<text class="sidebar-text">实时监控</text>
			</view>
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/report/index' }" 
				@click="navigateTo('/pages/admin/report/index')"
			>
				<text class="sidebar-icon">📊</text>
				<text class="sidebar-text">统计报表</text>
			</view>
			<view 
				class="sidebar-item" 
				:class="{ active: currentPath === '/pages/admin/profile/index' }" 
				@click="navigateTo('/pages/admin/profile/index')"
			>
				<text class="sidebar-icon">👤</text>
				<text class="sidebar-text">个人中心</text>
			</view>
		</view>
		
		<!-- 侧边栏底部 -->
		<view class="sidebar-footer">
			<view class="sidebar-item logout" @click="handleLogout">
				<text class="sidebar-icon">🚪</text>
				<text class="sidebar-text">退出登录</text>
			</view>
			<view class="sidebar-version">
				<text class="version-text">v1.0.0</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted } from 'vue'
	
	const currentPath = ref('')
	
	onMounted(() => {
		// 获取当前页面路径
		const pages = getCurrentPages()
		if (pages.length > 0) {
			currentPath.value = pages[pages.length - 1].route
		}
		
		// 监听页面显示事件，更新当前路径
		uni.onShow(() => {
			const pages = getCurrentPages()
			if (pages.length > 0) {
				currentPath.value = pages[pages.length - 1].route
			}
		})
	})
	
	function navigateTo(url) {
		uni.redirectTo({
			url: url
		})
	}
	
	function handleLogout() {
		uni.showModal({
			title: '退出登录',
			content: '确定要退出登录吗？',
			confirmText: '确定',
			cancelText: '取消',
			success: (res) => {
				if (res.confirm) {
					// 清除登录状态
					uni.removeStorageSync('loginStatus')
					uni.removeStorageSync('userRole')
					uni.removeStorageSync('userInfo')
					// 跳转到登录页面
					uni.redirectTo({
						url: '/pages/auth/login'
					})
				}
			}
		})
	}
</script>

