import { http } from '@/utils/request.uts'
import type { DriverVO, DriverVehicleVO } from '@/types/user'

export function getDriverById(id: string): Promise<DriverVO> {
  return http.get<DriverVO>(`/user/driver/${id}`)
}

export function getDriverByUserId(userId: string): Promise<DriverVO> {
  return http.get<DriverVO>(`/user/driver/user/${userId}`)
}

export function getDriverList(params: {
  driverName?: string
  status?: number
}): Promise<DriverVO[]> {
  return http.get<DriverVO[]>('/user/driver/list', params)
}

export function updateDriverStatus(driverId: string, status: number): Promise<void> {
  return http.put<void>(`/user/driver/${driverId}/status`, { status })
}

export function getAvailableDrivers(): Promise<DriverVO[]> {
  return http.get<DriverVO[]>('/user/driver/available')
}

export function selectBestDriver(params: {
  vehicleId?: string
  scheduledTime?: string
}): Promise<DriverVO> {
  return http.post<DriverVO>('/user/driver/best', params)
}

export function addCommonVehicle(userId: string, vehicleId: string): Promise<void> {
  return http.post<void>(`/user/driver/user/${userId}/common-vehicle`, { vehicleId })
}

export function removeCommonVehicle(userId: string, vehicleId: string): Promise<void> {
  return http.delete<void>(`/user/driver/user/${userId}/common-vehicle/${vehicleId}`)
}

export function setDefaultVehicle(userId: string, vehicleId: string): Promise<void> {
  return http.put<void>(`/user/driver/user/${userId}/common-vehicle/${vehicleId}/default`)
}

export function getCommonVehicles(userId: string): Promise<DriverVehicleVO[]> {
  return http.get<DriverVehicleVO[]>(`/user/driver/user/${userId}/common-vehicles`)
}
