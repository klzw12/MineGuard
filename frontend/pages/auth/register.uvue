		font-size: 36rpx;
		font-weight: bold;
		color: #333;
		margin-bottom: 10rpx;
	}
	
	.slogan {
		font-size: 24rpx;
		color: #666;
	}
	
	.form-section {
		flex: 1;
		width: 100%;
	}
	
	.form-item {
		margin-bottom: 25rpx;
	}
	
	.label {
		display: block;
		font-size: 24rpx;
		color: #333;
		margin-bottom: 10rpx;
	}
	
	.input {
		width: 100%;
		height: 80rpx;
		background-color: #fff;
		border-radius: 10rpx;
		padding: 0 30rpx;
		box-sizing: border-box;
		font-size: 28rpx;
		border: 1rpx solid #e5e5e5;
	}
	
	.register-btn {
		width: 100%;
		height: 88rpx;
		background-color: #007AFF;
		color: #fff;
		font-size: 32rpx;
		font-weight: bold;
		border-radius: 10rpx;
		margin-top: 40rpx;
		margin-bottom: 20rpx;
	}
	
	.auth-links {
		ttext-align: center;
		font-size: 24rpx;
	}
	
	.link {
		color: #007AFF;
	}
	
	.footer {
		margin-top: 40rpx;
		text-align: center;
	}
	
	.copyright {
		font-size: 20rpx;
		color: #999;
	}
	
	/* 响应式设计 */
	@media (min-width: 768px) {
		.register-container {
			max-width: 600rpx;
			margin: 0 auto;
			padding-top: 100rpx;
		}
		
		.form-item {
			margin-bottom: 30rpx;
		}
		
		.register-btn {
			margin-top: 50rpx;
		}
	}
