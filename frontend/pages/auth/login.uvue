<template>
	<view class="login-container">
		<view class="logo-section">
			<image class="logo" src="/static/logo/logo.png"></image>
			<text class="app-name">MineGuard</text>
			<text class="slogan">矿山安全智能监控系统</text>
		</view>
		
		<view class="form-section">
			<!-- 用户类型选择 -->
			<view class="user-type-section">
				<text class="type-label">登录类型</text>
				<view class="type-buttons">
					<view class="type-btn" :class="{ active: userType === 'admin' }" @click="selectUserType('admin')">
						<text>管理端</text>
					</view>
					<view class="type-btn" :class="{ active: userType === 'user' }" @click="selectUserType('user')">
						<text>用户端</text>
					</view>
				</view>
			</view>
			
			<!-- 登录表单 -->
			<view class="form-item">
				<text class="label">账号</text>
				<input 
					class="input" 
					type="text" 
					v-model="username" 
					placeholder="请输入账号" 
					placeholder-style="color: #999" 
					@focus="clearError('username')"
				/>
				<text v-if="errors.username" class="error-text">{{ errors.username }}</text>
			</view>
			
			<view class="form-item">
				<text class="label">密码</text>
				<input 
					class="input" 
					type="password" 
					v-model="password" 
					placeholder="请输入密码" 
					placeholder-style="color: #999" 
					@focus="clearError('password')"
				/>
				<text v-if="errors.password" class="error-text">{{ errors.password }}</text>
			</view>
			
			<button class="login-btn" @click="handleLogin" :disabled="isLoading">
				<text v-if="!isLoading">登录</text>
				<text v-else>登录中...</text>
			</button>
			
			<view class="auth-links">
				<navigator url="/pages/auth/register" class="link">注册账号</navigator>
				<text class="link" @click="forgotPassword">忘记密码？</text>
			</view>
		</view>
		
		<view class="footer">
			<text class="copyright">© 2026 MineGuard. 保留所有权利</text>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, reactive } from 'vue'
	
	const username = ref('')
	const password = ref('')
	const userType = ref('user') // 默认用户端
	const isLoading = ref(false)
	const errors = reactive({
		username: '',
		password: ''
	})
	
	function selectUserType(type) {
		userType.value = type
	}
	
	function clearError(field) {
		errors[field] = ''
	}
	
	function validateForm() {
		let isValid = true
		
		// 重置错误信息
		Object.keys(errors).forEach(key => {
			errors[key] = ''
		})
		
		// 验证账号
		if (!username.value.trim()) {
			errors.username = '请输入账号'
			isValid = false
		}
		
		// 验证密码
		if (!password.value.trim()) {
			errors.password = '请输入密码'
			isValid = false
		} else if (password.value.length < 6) {
			errors.password = '密码长度至少6位'
			isValid = false
		}
		
		return isValid
	}
	
	function handleLogin() {
		// 表单验证
		if (!validateForm()) {
			return
		}
		
		// 显示加载状态
		isLoading.value = true
		
		// 模拟登录请求
		setTimeout(() => {
			// 隐藏加载状态
			isLoading.value = false
			
			// 显示登录成功提示
			uni.showToast({
				title: '登录成功',
				icon: 'success',
				position: 'bottom'
			})
			
			// 存储登录状态和用户类型
			uni.setStorageSync('loginStatus', true)
			uni.setStorageSync('userRole', userType.value)
			uni.setStorageSync('userInfo', {
				name: username.value,
				role: userType.value === 'admin' ? '管理员' : '司机',
				id: 'U' + Math.floor(Math.random() * 1000000)
			})
			
			// 根据用户类型跳转到对应首页
			setTimeout(() => {
				if (userType.value === 'admin') {
					uni.redirectTo({
						url: '/pages/admin/home/index'
					})
				} else if (userType.value === 'user') {
					uni.switchTab({
						url: '/pages/user/home/index'
					})
				}
			}, 1000)
		}, 1500)
	}
	
	function forgotPassword() {
		// 跳转到忘记密码页面
		uni.navigateTo({
			url: '/pages/auth/reset-password'
		})
	}
</script>

<style lang="scss">
