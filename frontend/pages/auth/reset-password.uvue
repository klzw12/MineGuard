		background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
	}

	.logo-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 60rpx;
		animation: fadeIn 0.8s ease-out forwards;
	}

	.logo {
		width: 160rpx;
		height: 160rpx;
		margin-bottom: 30rpx;
		border-radius: $uni-border-radius-xxl;
		box-shadow: $uni-shadow-lg;
	}

	.app-name {
		font-size: 36rpx;
		font-weight: bold;
		color: $uni-color-primary;
		margin-bottom: 15rpx;
	}

