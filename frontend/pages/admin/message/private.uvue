		background-color: #FF3B30;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 8rpx;
		
		text {
			font-size: 18rpx;
			color: #fff;
		}
	}
	
	.chat-area {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	
	.chat-header {
		padding: 20rpx 25rpx;
		border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
		display: flex;
		flex-direction: column;
	}
	
	.chat-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.chat-subtitle {
		font-size: 22rpx;
		color: rgba(255, 255, 255, 0.5);
	}
	
	.message-list {
		flex: 1;
		padding: 20rpx;
		overflow-y: auto;
	}
	
	.message-item {
		display: flex;
		margin-bottom: 20rpx;
		
		&.sent {
			justify-content: flex-end;
			
			.message-bubble {
				background-color: #007AFF;
			}
		}
		
		&.received {
			justify-content: flex-start;
			
			.message-bubble {
				background-color: #2a3347;
			}
		}
	}
	
	.message-bubble {
		max-width: 70%;
		padding: 15rpx 20rpx;
		border-radius: 12rpx;
		display: flex;
		flex-direction: column;
	}
	
	.message-text {
		font-size: 24rpx;
		color: #fff;
		line-height: 1.5;
	}
	
	.message-time {
		font-size: 18rpx;
		color: rgba(255, 255, 255, 0.5);
		margin-top: 8rpx;
		align-self: flex-end;
	}
	
	.empty-state {
		flex: 1;
		display: flex;
		align-items: center;
