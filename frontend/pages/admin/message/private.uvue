<template>
	<view class="admin-layout-container">
		<AdminSidebar />
		<view class="admin-content">
			<view class="page-header">
				<text class="page-title">私聊消息</text>
			</view>
			
			<view class="chat-container">
				<view class="contact-list">
					<view class="list-header">
						<text class="list-title">联系人</text>
					</view>
					
					<view class="contact-item" 
						v-for="(contact, index) in contacts" 
						:key="index"
						:class="{ active: selectedContact?.id === contact.id }"
						@click="selectContact(contact)"
					>
						<view class="contact-avatar">
							<text>{{ contact.avatar }}</text>
						</view>
						<view class="contact-info">
							<text class="contact-name">{{ contact.name }}</text>
							<text class="contact-role">{{ contact.roleName }}</text>
						</view>
						<view class="contact-badge" v-if="contact.unread > 0">
							<text>{{ contact.unread }}</text>
						</view>
					</view>
				</view>
				
				<view class="chat-area">
					<view class="chat-header" v-if="selectedContact">
						<text class="chat-title">{{ selectedContact.name }}</text>
						<text class="chat-subtitle">{{ selectedContact.roleName }}</text>
					</view>
					
					<view class="message-list" v-if="selectedContact">
						<view class="message-item" 
							v-for="(msg, index) in messages" 
							:key="index"
							:class="{ sent: msg.sent, received: !msg.sent }"
						>
							<view class="message-bubble">
								<text class="message-text">{{ msg.content }}</text>
								<text class="message-time">{{ msg.time }}</text>
							</view>
						</view>
					</view>
					
					<view class="empty-state" v-else>
						<text class="empty-text">选择一个联系人开始聊天</text>
					</view>
					
					<view class="chat-input" v-if="selectedContact">
						<input class="message-input" 
							type="text" 
							placeholder="输入消息..." 
							placeholder-style="color: rgba(255,255,255,0.4)"
							v-model="inputMessage"
							@confirm="sendMessage"
						/>
						<view class="send-btn" @click="sendMessage">
							<text>发送</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'
	import AdminSidebar from '@/components/AdminSidebar.uvue'
	
	const selectedContact = ref<any>(null)
	const inputMessage = ref('')
	
	const contacts = ref([
		{ id: 1, name: '张师傅', roleName: '司机', avatar: '👨', unread: 2 },
		{ id: 2, name: '李师傅', roleName: '司机', avatar: '👨', unread: 0 },
		{ id: 3, name: '王维修', roleName: '维修员', avatar: '🔧', unread: 1 },
		{ id: 4, name: '赵安全', roleName: '安全员', avatar: '🛡️', unread: 0 },
		{ id: 5, name: '孙调度', roleName: '调度员', avatar: '📋', unread: 0 }
	])
	
	const messages = ref<any[]>([])
	
	function selectContact(contact: any) {
		selectedContact.value = contact
		
		messages.value = [
			{ content: '您好，请问有什么可以帮助您的？', time: '10:30', sent: false },
			{ content: '我想确认一下明天的任务安排', time: '10:32', sent: true },
			{ content: '好的，您明天的任务是运送货物到朝阳区，早上8点出发。', time: '10:33', sent: false },
			{ content: '收到，谢谢！', time: '10:35', sent: true }
		]
	}
	
	function sendMessage() {
		if (!inputMessage.value.trim()) return
		
		messages.value.push({
			content: inputMessage.value,
			time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' }),
			sent: true
		})
		
		inputMessage.value = ''
	}
</script>

<style lang="scss">
