	}
	
	.card-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.broadcast-list {
		padding: 20rpx 30rpx;
	}
	
	.broadcast-item {
		padding: 25rpx;
		background-color: rgba(255, 255, 255, 0.03);
		border-radius: 12rpx;
		margin-bottom: 20rpx;
	}
	
	.broadcast-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 15rpx;
	}
	
	.broadcast-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.broadcast-time {
		font-size: 22rpx;
		color: rgba(255, 255, 255, 0.5);
	}
	
	.broadcast-content {
		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
	}
	
	.empty-state {
		padding: 60rpx 30rpx;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	
	.empty-text {
		font-size: 26rpx;
		color: rgba(255, 255, 255, 0.4);
	}
</style>
