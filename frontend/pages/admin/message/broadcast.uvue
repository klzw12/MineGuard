		color: #fff;
	}
	
	.checkbox-group {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 20rpx;
	}
	
	.checkbox-item {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 10rpx;
	}
	
	.checkbox {
		width: 36rpx;
		height: 36rpx;
		border: 2rpx solid rgba(255, 255, 255, 0.3);
		border-radius: 6rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		
		&.checked {
			background-color: #007AFF;
			border-color: #007AFF;
		}
		
		text {
			color: #fff;
			font-size: 24rpx;
		}
	}
	
	.checkbox-label {
		font-size: 26rpx;
		color: rgba(255, 255, 255, 0.7);
	}
	
	.form-actions {
		margin-top: 40rpx;
	}
	
	.card-header {
		padding: 30rpx;
		border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
	}
	
	.card-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.broadcast-list {
		padding: 20rpx 30rpx;
	}
	
	.broadcast-item {
		padding: 25rpx;
		background-color: rgba(255, 255, 255, 0.03);
		border-radius: 12rpx;
		margin-bottom: 20rpx;
	}
	
	.broadcast-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 15rpx;
	}
	
	.broadcast-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.broadcast-time {
		font-size: 22rpx;
		color: rgba(255, 255, 255, 0.5);
	}
	
	.broadcast-content {
		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
		margin-bottom: 15rpx;
	}
	
	.broadcast-footer {
		display: flex;
		flex-direction: row;
	}
	
	.broadcast-target {
		font-size: 22rpx;
		color: #007AFF;
	}
</style>
