<template>
  <AdminLayout>
    <view class="container">
      <view class="header">
        <text class="title">角色变更申请管理</text>
      </view>
      
      <view class="tabs">
        <button 
          :class="['tab-btn', { active: activeTab === 'pending' }]"
          @tap="activeTab = 'pending'"
        >
          待处理
        </button>
        <button 
          :class="['tab-btn', { active: activeTab === 'all' }]"
          @tap="activeTab = 'all'"
        >
          全部申请
        </button>
      </view>
      
      <view class="list-container">
        <view v-if="loading" class="loading">
          <text>加载中...</text>
        </view>
        <view v-else-if="applies.length === 0" class="empty">
          <text>暂无申请</text>
        </view>
        <view v-else class="apply-list">
          <view v-for="apply in applies" :key="apply.id" class="apply-item">
            <view class="apply-header">
              <view class="user-info">
                <text class="username">{{ apply.username }}</text>
                <text class="status" :class="getStatusClass(apply.status)">
                  {{ apply.statusLabel }}
                </text>
              </view>
              <text class="create-time">{{ apply.createTime }}</text>
            </view>
            
            <view class="apply-content">
              <view class="role-info">
                <text class="label">当前角色：</text>
                <text class="role-name">{{ apply.currentRoleName }}</text>
              </view>
              <view class="role-info">
                <text class="label">申请角色：</text>
                <text class="role-name">{{ apply.applyRoleName }}</text>
              </view>
              <view class="reason">
                <text class="label">申请原因：</text>
                <text class="reason-text">{{ apply.applyReason }}</text>
              </view>
            </view>
            
            <view v-if="apply.status === 1" class="apply-actions">
              <button class="action-btn tac approve" @tap="handleApply(apply.id, 2)">
                批准
              </button>
              <button class="action-btn tac reject" @tap="handleApply(apply.id, 3)">
                拒绝
              </button>
            </view>
            
            <view v-else class="handle-info">
              <view v-if="apply.handleTime" class="handle-item">
                <text class="label">处理时间：</text>
                <text class="value">{{ apply.handleTime }}</text>
              </view>
              <view v-if="apply.handlerName" class="handle-item">
                <text class="label">处理人：</text>
                <text class="value">{{ apply.handlerName }}</text>
              </view>
              <view v-if="apply.adminOpinion" class="handle-item">
                <text class="label">处理意见：</text>
                <text class="value">{{ apply.adminOpinion }}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </AdminLayout>
</template>

<script setup lang="uts">
import { ref, onMounted, watch } from 'vue'
import AdminLayout from '@/components/AdminLayout.uvue'
import { getPendingRoleChangeApplies, getAllRoleChangeApplies, handleRoleChangeApply } from '@/api/user.uts'
import type { RoleChangeApplyVO } from '@/types/user.uts'

const activeTab = ref('pending')
const loading = ref(false)
const applies = ref<RoleChangeApplyVO[]>([])

const loadApplies = async () => {
  loading.value = true
  
  try {
    let result
    
    if (activeTab.value === 'pending') {
      result = await getPendingRoleChangeApplies()
    } else {
      result = await getAllRoleChangeApplies()
    }
    
    // 为每个申请添加状态标签
    applies.value = result.map(apply => ({
      ...apply,
      statusLabel: getStatusLabel(apply.status)
    }))
  } catch (error) {
    uni.showToast({ title: '加载失败', icon: 'none' })
  } finally {
    loading.value = false
  }
}

const getStatusLabel = (status: number): string => {
  switch (status) {
    case 1:
      return '待处理'
    case 2:
      return '已通过'
    case 3:
      return '已拒绝'
    default:
      return '未知'
  }
}

const getStatusClass = (status: number): string => {
  switch (status) {
    case 1:
      return 'status-pending'
    case 2:
      return 'status-approved'
    case 3:
      return 'status-rejected'
    default:
      return ''
  }
}

const handleApply = async (id: string, status: number) => {
  const adminInfo = uni.getStorageSync('adminInfo')
  if (!adminInfo || !adminInfo.id || !adminInfo.username) {
    uni.showToast({ title: '管理员信息缺失', icon: 'none' })
    return
  }
  
  try {
    await handleRoleChangeApply(id, status, '', adminInfo.id, adminInfo.username)
    uni.showToast({ title: status === 2 ? '批准成功' : '拒绝成功', icon: 'success' })
    // 重新加载数据
    loadApplies()
  } catch (error) {
    uni.showToast({ title: '处理失败', icon: 'none' })
  }
}

watch(activeTab, () => {
  loadApplies()
})

onMounted(() => {
  loadApplies()
})
</script>

