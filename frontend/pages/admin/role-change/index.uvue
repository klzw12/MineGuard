  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.username {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.status {
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-pending {
  background-color: #fff3cd;
  color: #856404;
}

.status-approved {
  background-color: #d4edda;
  color: #155724;
}

.status-rejected {
  background-color: #f8d7da;
  color: #721c24;
}

.create-time {
  font-size: 22rpx;
  color: #999;
}

.apply-content {
  margin-bottom: 20rpx;
}

.role-info {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.role-info .label {
  color: #666;
  width: 120rpx;
}

.role-info .role-name {
  color: #333;
  font-weight: bold;
}

.reason {
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
}

.reason .label {
  color: #666;
  margin-bottom: 5rpx;
}

.reason .reason-text {
  color: #333;
  line-height: 1.5;
}

.apply-actions {
  display: flex;
