<template>
	<AdminLayout>
		<view class="page-header">
			<text class="page-title">行程管理</text>
			<view class="header-actions">
				<button class="primary-btn" @click="showAddModal = true">创建行程</button>
			</view>
		</view>
		
		<view class="filter-section">
			<view class="filter-buttons">
				<button class="filter-btn" :class="{'active': currentStatus === null}" @click="filterByStatus(null)">全部</button>
				<button class="filter-btn" :class="{'active': currentStatus === 0}" @click="filterByStatus(0)">待开始</button>
				<button class="filter-btn" :class="{'active': currentStatus === 1}" @click="filterByStatus(1)">已接单</button>
				<button class="filter-btn" :class="{'active': currentStatus === 2}" @click="filterByStatus(2)">进行中</button>
				<button class="filter-btn" :class="{'active': currentStatus === 3}" @click="filterByStatus(3)">已完成</button>
			</view>
		</view>
		
		<view class="trip-card">
			<view class="trip-list">
				<view class="trip-item" v-for="(trip, index) in tripList" :key="trip.id">
					<view class="trip-left">
						<view class="trip-header">
							<text class="trip-no">📋 {{ trip.tripNo }}</text>
							<view class="trip-status" :class="getStatusClass(trip.status)">
								<text class="status-dot"></text>
								<text class="status-text">{{ getStatusText(trip.status) }}</text>
							</view>
						</view>
						<view class="trip-route">
							<text class="route-text">📍 {{ trip.startLocation }}</text>
							<text class="route-arrow">→</text>
							<text class="route-text">📍 {{ trip.endLocation }}</text>
						</view>
						<view class="trip-info">
							<text class="info-item">🚚 车辆：{{ trip.vehicleNo || trip.vehicleId }}</text>
							<text class="info-item">👤 司机：{{ trip.driverName || trip.driverId }}</text>
						</view>
						<view class="trip-time">
							<text class="time-item">预计：{{ trip.estimatedStartTime }} ~ {{ trip.estimatedEndTime }}</text>
							<text class="time-item" v-if="trip.actualStartTime">实际：{{ trip.actualStartTime }}</text>
						</view>
					</view>
					<view class="trip-right">
						<view class="action-buttons">
							<button class="action-btn" @click="viewDetail(trip)">详情</button>
							<button class="action-btn success" v-if="trip.status === 0" @click="acceptTrip(trip)">接单</button>
							<button class="action-btn warning" v-if="trip.status === 1" @click="startTrip(trip)">开始</button>
							<button class="action-btn danger" v-if="trip.status === 2" @click="endTrip(trip)">结束</button>
						</view>
					</view>
				</view>
				
				<view class="empty-state" v-if="tripList.length === 0">
					<text class="empty-text">暂无行程数据</text>
				</view>
			</view>
		</view>
		
		<view class="pagination" v-if="total > pageSize">
			<button class="page-btn" :disabled="currentPage === 1" @click="changePage(currentPage - 1)">上一页</button>
			<text class="page-info">{{ currentPage }} / {{ totalPages }}</text>
			<button class="page-btn" :disabled="currentPage >= totalPages" @click="changePage(currentPage + 1)">下一页</button>
		</view>
		
		<view class="modal-overlay" v-if="showAddModal" @click="showAddModal = false">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">创建行程</text>
					<text class="modal-close" @click="showAddModal = false">×</text>
				</view>
				<view class="modal-body">
					<view class="form-item">
						<text class="form-label">选择车辆 *</text>
						<picker mode="selector" :range="vehicleOptions" range-key="vehicleNo" @change="onVehicleChange">
							<view class="picker-input">
								<text class="picker-text">{{ formData.vehicleId ? getVehicleNo(formData.vehicleId) : '请选择车辆' }}</text>
								<text class="picker-arrow">▼</text>
							</view>
						</picker>
					</view>
					<view class="form-item">
						<text class="form-label">选择司机 *</text>
						<picker mode="selector" :range="driverOptions" range-key="name" @change="onDriverChange">
							<view class="picker-input">
								<text class="picker-text">{{ formData.driverId ? getDriverName(formData.driverId) : '请选择司机' }}</text>
								<text class="picker-arrow">▼</text>
							</view>
						</picker>
					</view>
					<view class="form-item">
						<text class="form-label">选择路线</text>
						<picker mode="selector" :range="routeOptions" range-key="routeName" @change="onRouteChange">
							<view class="picker-input">
								<text class="picker-text">{{ formData.routeId ? getRouteName(formData.routeId) : '请选择路线' }}</text>
								<text class="picker-arrow">▼</text>
							</view>
						</picker>
					</view>
					<view class="form-item">
						<text class="form-label">起始位置</text>
						<input type="text" v-model="formData.startLocation" class="form-input" placeholder="请输入起始位置" />
					</view>
					<view class="form-item">
						<text class="form-label">结束位置</text>
						<input type="text" v-model="formData.endLocation" class="form-input" placeholder="请输入结束位置" />
					</view>
					<view class="form-row">
						<view class="form-item half">
							<text class="form-label">预计开始时间</text>
							<picker mode="date" @change="onStartDateChange">
								<view class="picker-input">
									<text class="picker-text">{{ formData.estimatedStartTime || '请选择日期' }}</text>
								</view>
							</picker>
						</view>
						<view class="form-item half">
							<text class="form-label">预计结束时间</text>
							<picker mode="date" @change="onEndDateChange">
								<view class="picker-input">
									<text class="picker-text">{{ formData.estimatedEndTime || '请选择日期' }}</text>
								</view>
							</picker>
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click="showAddModal = false">取消</button>
					<button class="confirm-btn" @click="submitForm">创建</button>
				</view>
			</view>
		</view>
	</AdminLayout>
</template>

<script setup lang="uts">
	import AdminLayout from '../../../components/AdminLayout.uvue'
	import { ref, computed, onMounted } from 'vue'
	import { getTripList, startTrip as startTripApi, endTrip as endTripApi, acceptTrip as acceptTripApi, createTrip, type Trip, type PageResult } from '@/api/trip.uts'
	import { vehicleApi } from '@/api/vehicle.uts'
	import { getDriverList } from '@/api/driver.uts'
	import { getRouteTemplateList } from '@/api/dispatch.uts'

	type TripVO = Trip

	type VehicleOption = { id: string, vehicleNo: string }
	type DriverOption = { id: string, name: string }
	type RouteOption = { id: string, routeName: string }

	const tripList = ref<TripVO[]>([])
	const currentPage = ref(1)
	const pageSize = ref(10)
	const total = ref(0)
	const currentStatus = ref<number | null>(null)
	const showAddModal = ref(false)

	const vehicleOptions = ref<VehicleOption[]>([])
	const driverOptions = ref<DriverOption[]>([])
	const routeOptions = ref<RouteOption[]>([])

	const formData = ref({
		vehicleId: '',
		driverId: '',
		routeId: '',
		startLocation: '',
		endLocation: '',
		estimatedStartTime: '',
		estimatedEndTime: ''
	})

	const totalPages = computed(() => Math.ceil(total.value / pageSize.value))

	const getStatusClass = (status: number): string => {
		const map: Record<number, string> = {
			0: 'pending', 1: 'accepted', 2: 'in-progress', 3: 'completed', 4: 'cancelled'
		}
		return map[status] || 'pending'
	}

	const getStatusText = (status: number): string => {
		const map: Record<number, string> = {
			0: '待开始', 1: '已接单', 2: '进行中', 3: '已完成', 4: '已取消'
		}
		return map[status] || '未知'
	}

	const getVehicleNo = (id: string): string => {
		const v = vehicleOptions.value.find(item => item.id === id)
		return v ? v.vehicleNo : ''
	}

	const getDriverName = (id: string): string => {
		const d = driverOptions.value.find(item => item.id === id)
		return d ? d.name : ''
	}

	const getRouteName = (id: string): string => {
		const r = routeOptions.value.find(item => item.id === id)
		return r ? r.routeName : ''
	}

	const fetchTripList = async () => {
		try {
			const res = await getTripList({ page: currentPage.value, size: pageSize.value, status: currentStatus.value })
			if (res) {
				tripList.value = res.records || []
				total.value = res.total || 0
			}
		} catch (e) {
			console.error('获取行程列表失败', e)
		}
	}

	const fetchOptions = async () => {
		try {
			const [vehicleRes, driverRes, routeRes] = await Promise.all([
			vehicleApi.getVehiclePage({ page: 1, size: 100 }),
			getDriverList({}),
			getRouteTemplateList()
		])
			if (vehicleRes) {
				vehicleOptions.value = (vehicleRes.records || []).map((v: any) => ({ id: String(v.id), vehicleNo: v.vehicleNo }))
			}
			if (driverRes) {
				driverOptions.value = (driverRes || []).map((d: any) => ({ id: String(d.id), name: d.realName || d.username }))
			}
			if (routeRes) {
				routeOptions.value = (routeRes || []).map((r: any) => ({ id: String(r.id), routeName: r.routeName }))
			}
		} catch (e) {
			console.error('获取选项失败', e)
		}
	}

	const filterByStatus = (status: number | null) => {
		currentStatus.value = status
		currentPage.value = 1
		fetchTripList()
	}

	const changePage = (page: number) => {
		currentPage.value = page
		fetchTripList()
	}

	const viewDetail = (trip: TripVO) => {
		uni.navigateTo({ url: `/pages/admin/trip/detail?id=${trip.id}` })
	}

	const acceptTrip = async (trip: TripVO) => {
		try {
			await acceptTripApi(Number(trip.id))
			uni.showToast({ title: '接单成功', icon: 'success' })
			fetchTripList()
		} catch (e) {
			uni.showToast({ title: '接单失败', icon: 'none' })
		}
	}

	const startTrip = async (trip: TripVO) => {
		try {
			await startTripApi(String(trip.id))
			uni.showToast({ title: '行程开始', icon: 'success' })
			fetchTripList()
		} catch (e) {
			uni.showToast({ title: '操作失败', icon: 'none' })
		}
	}

	const endTrip = async (trip: TripVO) => {
		uni.showModal({
			title: '确认结束',
			content: '确定要结束该行程吗？',
			success: async (res) => {
				if (res.confirm) {
					try {
						await endTripApi(String(trip.id))
						uni.showToast({ title: '行程已结束', icon: 'success' })
						fetchTripList()
					} catch (e) {
						uni.showToast({ title: '操作失败', icon: 'none' })
					}
				}
			}
		})
	}

	const onVehicleChange = (e: any) => { formData.value.vehicleId = vehicleOptions.value[e.detail.value].id }
	const onDriverChange = (e: any) => { formData.value.driverId = driverOptions.value[e.detail.value].id }
	const onRouteChange = (e: any) => { formData.value.routeId = routeOptions.value[e.detail.value].id }
	const onStartDateChange = (e: any) => { formData.value.estimatedStartTime = e.detail.value }
	const onEndDateChange = (e: any) => { formData.value.estimatedEndTime = e.detail.value }

	const submitForm = async () => {
		if (!formData.value.vehicleId || !formData.value.driverId) {
			uni.showToast({ title: '请选择车辆和司机', icon: 'none' })
			return
		}
		try {
			await createTrip(formData.value)
			uni.showToast({ title: '创建成功', icon: 'success' })
			showAddModal.value = false
			fetchTripList()
		} catch (e) {
			uni.showToast({ title: '创建失败', icon: 'none' })
		}
	}

	onMounted(() => {
		fetchTripList()
		fetchOptions()
	})
</script>

