							&.pending { background-color: rgba(255, 149, 0, 0.2); color: #FF9500; }
							&.accepted { background-color: rgba(0, 122, 255, 0.2); color: #007AFF; }
							&.in-progress { background-color: rgba(52, 199, 89, 0.2); color: #34C759; }
							&.completed { background-color: rgba(142, 142, 147, 0.2); color: #8E8E93; }
							&.cancelled { background-color: rgba(255, 59, 48, 0.2); color: #FF3B30; }
							
