							&.success { background: linear-gradient(135deg, #34C759 0%, #28a745 100%); }
							&.warning { background: linear-gradient(135deg, #FF9500 0%, #FF6600 100%); }
							&.danger { background: linear-gradient(135deg, #FF3B30 0%, #d32f2f 100%); }
						}
					}
				}
			}
			
			.empty-state {
				padding: 80rpx;
				text-align: center;
				
				.empty-text {
					color: rgba(255, 255, 255, 0.5);
					font-size: 28rpx;
				}
			}
		}
	}
	
	.pagination {
