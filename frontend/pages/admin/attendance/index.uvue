<template>
	<view class="admin-container">
		<AdminSidebar />
		
		<view class="admin-content">
			<view class="header-section">
				<text class="page-title">出勤管理</text>
			</view>
			
			<view class="search-filter-section">
				<view class="date-picker">
					<text class="date-label">选择日期：</text>
					<picker mode="date" :value="selectedDate" @change="onDateChange">
						<view class="picker-value">{{ selectedDate }}</view>
					</picker>
				</view>
				<view class="search-bar">
					<text class="search-icon">🔍</text>
					<input type="text" v-model="searchName" placeholder="搜索司机姓名" placeholder-style="color: #999" @confirm="loadAttendanceList" />
				</view>
			</view>
			
			<view class="stats-section">
				<view class="stat-card">
					<text class="stat-value">{{ statistics.totalDays || 0 }}</text>
					<text class="stat-label">应出勤</text>
				</view>
				<view class="stat-card success">
					<text class="stat-value">{{ statistics.normalDays || 0 }}</text>
					<text class="stat-label">正常出勤</text>
				</view>
				<view class="stat-card warning">
					<text class="stat-value">{{ statistics.lateDays || 0 }}</text>
					<text class="stat-label">迟到</text>
				</view>
				<view class="stat-card danger">
					<text class="stat-value">{{ statistics.absentDays || 0 }}</text>
					<text class="stat-label">缺勤</text>
				</view>
			</view>
			
			<view class="attendance-list-section">
				<text class="section-title">出勤记录</text>
				<view class="attendance-list" v-if="attendanceList.length > 0">
					<view class="attendance-item" v-for="(item, index) in attendanceList" :key="item.id">
						<view class="attendance-info">
							<text class="driver-name">{{ item.driverName }}</text>
							<text class="attendance-time">上班：{{ item.checkInTime || '未打卡' }}</text>
							<text class="attendance-time">下班：{{ item.checkOutTime || '未打卡' }}</text>
						</view>
						<view class="attendance-status" :class="getStatusClass(item.status)">
							<text class="status-text">{{ item.statusLabel }}</text>
						</view>
					</view>
				</view>
				<view class="empty-list" v-else>
					<text class="empty-text">暂无出勤记录</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted } from 'vue'
	import AdminSidebar from '../../../components/AdminSidebar.uvue'
	import { getAttendanceListByMonth, getAttendanceStatistics } from '../../../api/attendance'
	import type { AttendanceVO, AttendanceStatisticsVO } from '../../../types/user'

	const selectedDate = ref(new Date().toISOString().split('T')[0])
	const searchName = ref('')
	const attendanceList = ref<AttendanceVO[]>([])
	const statistics = ref<AttendanceStatisticsVO>({
		totalDays: 0,
		normalDays: 0,
		lateDays: 0,
		earlyLeaveDays: 0,
		absentDays: 0,
		attendanceRate: 0
	})

	const onDateChange = (e: any) => {
		selectedDate.value = e.detail.value
		loadAttendanceList()
	}

	const loadAttendanceList = async () => {
		try {
			const yearMonth = selectedDate.value.substring(0, 7)
			const result = await getAttendanceListByMonth('', yearMonth)
			attendanceList.value = result || []
			
			const stats = await getAttendanceStatistics('', yearMonth)
			if (stats) {
				statistics.value = stats
			}
		} catch (e) {
			console.error('加载出勤记录失败', e)
		}
	}

	const getStatusClass = (status: number): string => {
		if (status === 1) return 'normal'
		if (status === 2) return 'late'
		if (status === 3) return 'early'
		if (status === 4) return 'absent'
		if (status === 5) return 'leave'
		return 'unknown'
	}

	onMounted(() => {
		loadAttendanceList()
	})
</script>

