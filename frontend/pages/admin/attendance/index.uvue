		flex: 1;
		font-size: 28rpx;
		color: #333;
	}
	
	.stats-section {
		display: flex;
		flex-direction: row;
		gap: 20rpx;
		margin-bottom: 30rpx;
	}
	
	.stat-card {
		flex: 1;
		background-color: #fff;
		border-radius: 15rpx;
		padding: 25rpx;
		text-align: center;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.stat-card.success {
		border-left: 4rpx solid #34C759;
	}
	
	.stat-card.warning {
		border-left: 4rpx solid #FF9500;
	}
	
	.stat-card.danger {
		border-left: 4rpx solid #FF3B30;
	}
	
	.stat-value {
		font-size: 36rpx;
		font-weight: bold;
		color: #333;
		display: block;
		margin-bottom: 8rpx;
	}
	
	.stat-label {
		font-size: 24rpx;
		color: #666;
	}
	
	.attendance-list-section {
		margin-bottom: 30rpx;
	}
	
	.section-title {
		font-size: 28rpx;
