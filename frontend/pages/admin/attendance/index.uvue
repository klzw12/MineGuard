		font-size: 32rpx;
		font-weight: bold;
		color: #0056b3;
	}
	
	.search-filter-section {
		margin-bottom: 30rpx;
	}
	
	.date-picker {
		display: flex;
		flex-direction: row;
		align-items: center;
		margin-bottom: 20rpx;
	}
	
	.date-label {
		font-size: 28rpx;
		color: #666;
		margin-right: 15rpx;
	}
	
	.picker-value {
		padding: 15rpx 30rpx;
		background-color: #fff;
		border-radius: 10rpx;
		font-size: 28rpx;
		color: #333;
	}
	
	.search-bar {
		display: flex;
		flex-direction: row;
		align-items: center;
		background-color: #fff;
		border-radius: 15rpx;
		padding: 20rpx;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.search-icon {
		margin-right: 15rpx;
		font-size: 24rpx;
		color: #999;
	}
	
