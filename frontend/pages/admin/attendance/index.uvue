		margin-bottom: 20rpx;
	}
	
	.attendance-list {
		background-color: #fff;
		border-radius: 20rpx;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.attendance-item {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 30rpx;
		border-bottom: 1rpx solid #f0f0f0;
	}
	
	.attendance-item:last-child {
		border-bottom: none;
	}
	
	.attendance-info {
		flex: 1;
	}
	
	.driver-name {
		font-size: 28rpx;
		font-weight: bold;
		color: #333;
		margin-bottom: 8rpx;
		display: block;
	}
	
	.attendance-time {
		font-size: 24rpx;
		color: #666;
		margin-bottom: 4rpx;
		display: block;
	}
	
	.attendance-status {
		padding: 8rpx 20rpx;
		border-radius: 20rpx;
	}
	
	.attendance-status.normal {
		background-color: #34C759;
