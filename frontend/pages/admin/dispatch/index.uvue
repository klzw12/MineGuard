		max-height: 600rpx;
		overflow-y: auto;
	}
	
	.form-item {
		margin-bottom: 24rpx;
	}
	
	.form-label {
		display: block;
		font-size: 26rpx;
		color: rgba(255, 255, 255, 0.7);
