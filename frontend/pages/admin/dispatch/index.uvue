	}
	
	.modal-mask {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
	}
	
	.modal-content {
		position: relative;
		width: 600rpx;
		background-color: #1c1c1e;
		border-radius: 20rpx;
		overflow: hidden;
	}
	
	.modal-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
