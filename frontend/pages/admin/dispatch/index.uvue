		display: flex;
		flex-direction: row;
		gap: 16rpx;
		
		.action-btn {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 8rpx;
			padding: 16rpx 32rpx;
			border-radius: 12rpx;
			font-size: 26rpx;
			transition: all 0.2s;
			
			&.primary {
				background-color: #007AFF;
				color: #fff;
			}
			
			&.secondary {
				background-color: rgba(255, 255, 255, 0.1);
				color: rgba(255, 255, 255, 0.7);
			}
		}
	}
	
	.status-tag {
		padding: 6rpx 16rpx;
		border-radius: 8rpx;
		font-size: 22rpx;
		
		&.pending {
			background-color: rgba(255, 149, 0, 0.2);
			color: #FF9500;
		}
		
		&.accepted {
			background-color: rgba(0, 122, 255, 0.2);
			color: #007AFF;
		}
		
		&.in-progress {
			background-color: rgba(88, 86, 214, 0.2);
			color: #5856D6;
		}
		
		&.completed {
			background-color: rgba(52, 199, 89, 0.2);
			color: #34C759;
		}
		
		&.cancelled {
			background-color: rgba(142, 142, 147, 0.2);
			color: #8E8E93;
		}
	}
	
	.priority-tag {
		padding: 4rpx 12rpx;
		border-radius: 6rpx;
		font-size: 20rpx;
		
		&.high {
			background-color: rgba(255, 59, 48, 0.2);
			color: #FF3B30;
		}
		
		&.medium {
			background-color: rgba(255, 149, 0, 0.2);
			color: #FF9500;
		}
		
		&.low {
			background-color: rgba(52, 199, 89, 0.2);
			color: #34C759;
		}
	}
	
	.action-link {
		color: #007AFF;
		font-size: 24rpx;
		margin-right: 20rpx;
		
		&.danger {
			color: #FF3B30;
		}
	}
	
	.table-cell {
		&.col-taskNo { width: 180rpx; }
		&.col-route { width: 240rpx; }
		&.col-driver { width: 120rpx; }
		&.col-vehicle { width: 120rpx; }
		&.col-time { width: 140rpx; }
		&.col-priority { width: 100rpx; }
		&.col-status { width: 100rpx; }
		&.col-actions { width: 160rpx; }
	}
	
	.loading-state {
		display: flex;
		justify-content: center;
		padding: 60rpx 0;
	}
	
	.loading-text {
		font-size: 28rpx;
		color: rgba(255, 255, 255, 0.5);
	}
	
	.empty-row {
		display: flex;
		justify-content: center;
		padding: 60rpx 0;
	}
	
	.empty-text {
		font-size: 28rpx;
		color: rgba(255, 255, 255, 0.4);
	}
	
	.create-modal {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
