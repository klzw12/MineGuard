	}
	
	.vehicle-default {
		font-size: 22rpx;
		color: #007AFF;
		padding: 4rpx 12rpx;
		border: 1rpx solid #007AFF;
		border-radius: 10rpx;
	}
	
	.modal-footer {
		display: flex;
		flex-direction: row;
		gap: 15rpx;
		padding: 20rpx 30rpx 30rpx;
	}
	
	.btn-status {
		flex: 1;
		padding: 20rpx;
		background-color: #007AFF;
		color: #fff;
		font-size: 26rpx;
		border-radius: 10rpx;
	}
	
	.btn-status.danger {
		background-color: #FF3B30;
	}
</style>
