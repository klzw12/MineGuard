		margin-bottom: 30rpx;
	}
	
	.page-title {
		font-size: 32rpx;
		font-weight: bold;
		color: #0056b3;
	}
	
	.search-filter-section {
		margin-bottom: 40rpx;
	}
	
	.search-bar {
		display: flex;
		flex-direction: row;
		align-items: center;
		background-color: #fff;
		border-radius: 15rpx;
		padding: 20rpx;
		margin-bottom: 20rpx;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.search-icon {
		margin-right: 15rpx;
		font-size: 24rpx;
		color: #999;
	}
	
	.search-bar input {
		flex: 1;
		font-size: 28rpx;
		color: #333;
	}
	
	.filter-buttons {
		display: flex;
		flex-direction: row;
		gap: 15rpx;
	}
	
	.filter-btn {
		flex: 1;
		padding: 15rpx;
		background-color: #fff;
		border-radius: 15rpx;
		font-size: 24rpx;
		color: #666;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.filter-btn.active {
		background-color: #007AFF;
		color: #fff;
	}
	
	.driver-list-section {
		margin-bottom: 60rpx;
	}
	
	.section-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #0056b3;
		margin-bottom: 20rpx;
	}
	
	.driver-list {
		background-color: #fff;
		border-radius: 20rpx;
		box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
	}
	
	.driver-item {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 30rpx;
		border-bottom: 1rpx solid #f0f0f0;
	}
	
	.driver-item:last-child {
		border-bottom: none;
	}
	
	.driver-info {
		flex: 1;
	}
	
	.driver-name {
		font-size: 28rpx;
		font-weight: bold;
		color: #333;
		margin-bottom: 8rpx;
		display: block;
	}
	
	.driver-id {
		font-size: 24rpx;
		color: #666;
		margin-bottom: 8rpx;
		display: block;
	}
	
	.driver-vehicle {
		font-size: 22rpx;
		color: #999;
		display: block;
	}
	
	.driver-status {
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 8rpx 20rpx;
		border-radius: 20rpx;
	}
	
	.driver-status.online {
		background-color: #34C759;
		color: #fff;
	}
	
	.driver-status.vacation {
		background-color: #FF9500;
		color: #fff;
	}
	
	.driver-status.stopped {
		background-color: #FF3B30;
		color: #fff;
	}
	
	.driver-status.offline {
		background-color: #999;
		color: #fff;
	}
	
	.status-dot {
		width: 12rpx;
		height: 12rpx;
		border-radius: 50%;
		background-color: currentColor;
		margin-right: 8rpx;
	}
	
	.status-text {
		font-size: 22rpx;
	}
	
	.empty-list {
		padding: 60rpx;
		text-align: center;
	}
	
	.empty-text {
		color: #999;
