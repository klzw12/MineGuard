<template>
	<view class="admin-container">
		<AdminSidebar />
		
		<view class="admin-content">
			<view class="header-section">
				<text class="page-title">司机管理</text>
			</view>
			
			<view class="search-filter-section">
				<view class="search-bar">
					<text class="search-icon">🔍</text>
					<input type="text" v-model="searchName" placeholder="搜索司机姓名" placeholder-style="color: #999" @confirm="handleSearch" />
				</view>
				<view class="filter-buttons">
					<button class="filter-btn" :class="{ active: statusFilter === null }" @click="statusFilter = null; loadDrivers()">全部</button>
					<button class="filter-btn" :class="{ active: statusFilter === 1 }" @click="statusFilter = 1; loadDrivers()">在职</button>
					<button class="filter-btn" :class="{ active: statusFilter === 2 }" @click="statusFilter = 2; loadDrivers()">休假</button>
					<button class="filter-btn" :class="{ active: statusFilter === 3 }" @click="statusFilter = 3; loadDrivers()">停职</button>
				</view>
			</view>
			
			<view class="driver-list-section">
				<text class="section-title">司机列表 (共{{ drivers.length }}人)</text>
				<view class="driver-list" v-if="drivers.length > 0">
					<view class="driver-item" v-for="(driver, index) in drivers" :key="driver.id" @click="showDriverDetail(driver)">
						<view class="driver-info">
							<text class="driver-name">{{ driver.driverName }}</text>
							<text class="driver-id">驾照类型：{{ driver.licenseType || '未录入' }}</text>
							<text class="driver-vehicle">驾龄：{{ driver.drivingYears || 0 }}年 | 班组：{{ driver.belongingTeam || '未分配' }}</text>
						</view>
						<view class="driver-status" :class="getStatusClass(driver.status)">
							<text class="status-dot"></text>
							<text class="status-text">{{ driver.statusName }}</text>
						</view>
					</view>
				</view>
				<view class="empty-list" v-else>
					<text class="empty-text">暂无司机数据</text>
				</view>
			</view>
		</view>
		
		<view class="driver-detail-modal" v-if="selectedDriver" @click="selectedDriver = null">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">司机详情</text>
					<text class="modal-close" @click="selectedDriver = null">×</text>
				</view>
				<view class="modal-body">
					<view class="detail-row">
						<text class="detail-label">姓名：</text>
						<text class="detail-value">{{ selectedDriver.driverName }}</text>
					</view>
					<view class="detail-row">
						<text class="detail-label">性别：</text>
						<text class="detail-value">{{ selectedDriver.genderName }}</text>
					</view>
					<view class="detail-row">
						<text class="detail-label">驾照类型：</text>
						<text class="detail-value">{{ selectedDriver.licenseType || '未录入' }}</text>
					</view>
					<view class="detail-row">
						<text class="detail-label">驾龄：</text>
						<text class="detail-value">{{ selectedDriver.drivingYears || 0 }}年</text>
					</view>
					<view class="detail-row">
						<text class="detail-label">班组：</text>
						<text class="detail-value">{{ selectedDriver.belongingTeam || '未分配' }}</text>
					</view>
					<view class="detail-row">
						<text class="detail-label">状态：</text>
						<text class="detail-value">{{ selectedDriver.statusName }}</text>
					</view>
					
					<view class="common-vehicles-section" v-if="selectedDriver.commonVehicles && selectedDriver.commonVehicles.length > 0">
						<text class="section-subtitle">常用车辆</text>
						<view class="vehicle-item" v-for="v in selectedDriver.commonVehicles" :key="v.vehicleId">
							<text class="vehicle-no">{{ v.vehicleNo }}</text>
							<text class="vehicle-use">使用{{ v.useCount }}次</text>
							<text class="vehicle-default" v-if="v.isDefault">默认</text>
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="btn-status" @click="changeStatus(1)" v-if="selectedDriver.status !== 1">设为在职</button>
					<button class="btn-status" @click="changeStatus(2)" v-if="selectedDriver.status !== 2">设为休假</button>
					<button class="btn-status danger" @click="changeStatus(3)" v-if="selectedDriver.status !== 3">设为停职</button>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted } from 'vue'
	import AdminSidebar from '../../../components/AdminSidebar.uvue'
	import { getDriverList, updateDriverStatus } from '../../../api/driver'
	import type { DriverVO } from '../../../types/user'

	const searchName = ref('')
	const statusFilter = ref<number | null>(null)
	const drivers = ref<DriverVO[]>([])
	const selectedDriver = ref<DriverVO | null>(null)

	const loadDrivers = async () => {
		try {
			const result = await getDriverList({
				driverName: searchName.value || undefined,
				status: statusFilter.value || undefined
			})
			drivers.value = result || []
		} catch (e) {
			console.error('加载司机列表失败', e)
		}
	}

	const handleSearch = () => {
		loadDrivers()
	}

	const showDriverDetail = (driver: DriverVO) => {
		selectedDriver.value = driver
	}

	const getStatusClass = (status: number): string => {
		if (status === 1) return 'online'
		if (status === 2) return 'vacation'
		if (status === 3) return 'stopped'
		return 'offline'
	}

	const changeStatus = async (newStatus: number) => {
		if (!selectedDriver.value) return
		try {
			await updateDriverStatus(selectedDriver.value.id, newStatus)
			selectedDriver.value.status = newStatus
			selectedDriver.value.statusName = newStatus === 1 ? '在职' : newStatus === 2 ? '休假' : '停职'
			loadDrivers()
		} catch (e) {
			console.error('更新状态失败', e)
		}
	}

	onMounted(() => {
		loadDrivers()
	})
</script>

