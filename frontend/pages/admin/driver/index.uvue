	}
	
	.modal-title {
		font-size: 32rpx;
		font-weight: bold;
		color: #fff;
	}
	
	.modal-close {
		font-size: 40rpx;
		color: #fff;
	}
	
	.modal-body {
		padding: 30rpx;
	}
	
	.detail-row {
		display: flex;
		flex-direction: row;
		margin-bottom: 20rpx;
	}
	
	.detail-label {
		width: 160rpx;
		font-size: 28rpx;
		color: #666;
	}
	
	.detail-value {
		flex: 1;
		font-size: 28rpx;
