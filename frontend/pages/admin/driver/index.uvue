	}
	
	.section-subtitle {
		font-size: 28rpx;
		font-weight: bold;
		color: #0056b3;
		margin: 20rpx 0 15rpx 0;
		display: block;
	}
	
	.vehicle-item {
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 15rpx;
		background-color: #f5f5f5;
		border-radius: 10rpx;
		margin-bottom: 10rpx;
	}
	
	.vehicle-no {
		font-size: 26rpx;
