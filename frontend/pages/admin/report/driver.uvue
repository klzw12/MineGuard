		color: #fff;
	}
	
	.ranking-list {
		padding: 20rpx 30rpx;
	}
	
	.ranking-item {
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 20rpx;
		background-color: rgba(255, 255, 255, 0.03);
		border-radius: 12rpx;
		margin-bottom: 15rpx;
	}
	
	.ranking-position {
		width: 50rpx;
		height: 50rpx;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-right: 20rpx;
		background-color: #2a3347;
		
		&.pos-1 {
			background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
		}
		
		&.pos-2 {
			background: linear-gradient(135deg, #C0C0C0 0%, #A0A0A0 100%);
		}
		
		&.pos-3 {
			background: linear-gradient(135deg, #CD7F32 0%, #8B4513 100%);
		}
		
		text {
			font-size: 24rpx;
			font-weight: bold;
			color: #fff;
		}
	}
	
	.ranking-info {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	
	.ranking-name {
		font-size: 26rpx;
		font-weight: bold;
		color: #fff;
		margin-bottom: 5rpx;
	}
	
	.ranking-stats {
		font-size: 22rpx;
		color: rgba(255, 255, 255, 0.5);
	}

	.ranking-cost {
		font-size: 20rpx;
		color: #007AFF;
		margin-top: 5rpx;
	}
	
	.ranking-score {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
	}
	
	.score-value {
		font-size: 32rpx;
		font-weight: bold;
		color: #007AFF;
	}
	
	.score-label {
		font-size: 20rpx;
		color: rgba(255, 255, 255, 0.5);
	}
	
	.status-tag {
				padding: 6rpx 16rpx;
				border-radius: 8rpx;
				font-size: 22rpx;
				
				&.active {
					background-color: rgba(52, 199, 89, 0.2);
					color: #34C759;
				}
				
				&.rest {
					background-color: rgba(255, 149, 0, 0.2);
					color: #FF9500;
				}
				
				&.leave {
					background-color: rgba(255, 59, 48, 0.2);
					color: #FF3B30;
				}
			}

		.action-btn.calculate {
			background: linear-gradient(135deg, #FF9500 0%, #FF6600 100%);
			box-shadow: 0 4rpx 20rpx rgba(255, 149, 0, 0.3);
		}
</style>
