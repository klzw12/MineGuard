<template>
	<view class="admin-layout-container">
		<AdminSidebar />
		<view class="admin-content">
			<view class="page-header">
				<text class="page-title">司机报表</text>
				<view class="header-actions">
				<view class="action-btn" @click="exportReport">
					<text class="action-text">导出报表</text>
				</view>
				<view class="action-btn calculate" @click="calculateStatistics">
					<text class="action-text">触发统计</text>
				</view>
			</view>
			</view>
			
			<view class="stats-grid">
			<view class="stat-card">
				<text class="stat-value">{{ driverStats.total || 0 }}</text>
				<text class="stat-label">司机总数</text>
				<text class="stat-trend positive">↑ 8%</text>
			</view>
			<view class="stat-card">
				<text class="stat-value">{{ driverStats.onDuty || 0 }}</text>
				<text class="stat-label">在岗</text>
				<text class="stat-trend positive">↑ 5%</text>
			</view>
			<view class="stat-card">
				<text class="stat-value">{{ driverStats.onRest || 0 }}</text>
				<text class="stat-label">休息中</text>
				<text class="stat-trend">-</text>
			</view>
			<view class="stat-card">
				<text class="stat-value">{{ driverStats.onLeave || 0 }}</text>
				<text class="stat-label">请假</text>
				<text class="stat-trend negative">↓ 2%</text>
			</view>
		</view>
			
			<view class="content-card">
				<view class="card-header">
					<text class="card-title">司机绩效排名</text>
				</view>
				
				<view class="ranking-list">
					<view class="ranking-item" v-for="(driver, index) in driverRanking" :key="index">
						<view class="ranking-position" :class="'pos-' + (index + 1)">
							<text>{{ index + 1 }}</text>
						</view>
						<view class="ranking-info">
							<text class="ranking-name">{{ driver.name }}</text>
							<text class="ranking-stats">完成任务: {{ driver.tasks }} | 预警: {{ driver.warningCount || 0 }}次</text>
							<text class="ranking-cost">成本: ¥{{ driver.totalCost?.toFixed(2) || '0.00' }} | 提成: ¥{{ driver.commission?.toFixed(2) || '0.00' }}</text>
						</view>
						<view class="ranking-score">
							<text class="score-value">{{ driver.score }}</text>
							<text class="score-label">绩效评分</text>
						</view>
					</view>
				</view>
			</view>
			
			<view class="content-card">
				<view class="card-header">
					<text class="card-title">司机出勤统计</text>
				</view>
				
				<view class="table-container">
					<view class="table-row header">
						<text class="table-cell">司机姓名</text>
						<text class="table-cell">出勤天数</text>
						<text class="table-cell">迟到次数</text>
						<text class="table-cell">早退次数</text>
						<text class="table-cell">状态</text>
					</view>
					
					<view class="table-row" v-for="(driver, index) in attendanceStats" :key="index">
						<text class="table-cell">{{ driver.name }}</text>
						<text class="table-cell">{{ driver.days }}</text>
						<text class="table-cell">{{ driver.late }}</text>
						<text class="table-cell">{{ driver.early }}</text>
						<view class="table-cell">
							<view class="status-tag" :class="driver.statusClass">
								<text>{{ driver.status }}</text>
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted } from 'vue'
	import AdminSidebar from '@/components/AdminSidebar.uvue'
	import { statisticsApi } from '@/api/statistics.uts'
	import type { DriverStatisticsVO } from '@/api/statistics.uts'
	
	const loading = ref(false)
	const driverRanking = ref([])
	const attendanceStats = ref([])
	const driverStats = ref({
		total: 0,
		onDuty: 0,
		onRest: 0,
		onLeave: 0
	})
	
	async function loadDriverStatistics() {
		loading.value = true
		try {
			// 获取司机统计数据
			const result = await statisticsApi.getDriverStatistics({
				startDate: new Date().toISOString().split('T')[0],
				endDate: new Date().toISOString().split('T')[0]
			})
			
			if (result) {
				// 处理司机排名数据
				driverRanking.value = result
					.filter((driver: DriverStatisticsVO) => driver.performanceScore > 0)
					.sort((a: DriverStatisticsVO, b: DriverStatisticsVO) => b.performanceScore - a.performanceScore)
					.slice(0, 5)
					.map((driver: DriverStatisticsVO) => ({
						name: driver.userName,
						tasks: driver.tripCount || 0,
						warningCount: driver.warningCount || 0,
						totalCost: driver.totalCost || 0,
						commission: driver.commissionAmount || 0,
						score: driver.performanceScore || 0
					}))
				
				// 处理出勤统计数据
				attendanceStats.value = result.map((driver: DriverStatisticsVO) => {
					let status = '在岗'
					let statusClass = 'active'
					
					// 简单模拟状态判断
					if (driver.attendanceDays < 10) {
						status = '请假'
						statusClass = 'leave'
					} else if (driver.attendanceDays < 20) {
						status = '休息'
						statusClass = 'rest'
					}
					
					return {
						name: driver.userName,
						days: driver.attendanceDays || 0,
						late: driver.lateCount || 0,
						early: driver.earlyLeaveCount || 0,
						status,
						statusClass
					}
				})
				
				// 计算司机状态统计
				driverStats.value = {
					total: result.length,
					onDuty: attendanceStats.value.filter(item => item.statusClass === 'active').length,
					onRest: attendanceStats.value.filter(item => item.statusClass === 'rest').length,
					onLeave: attendanceStats.value.filter(item => item.statusClass === 'leave').length
				}
			}
		} catch (e: any) {
			uni.showToast({ title: e.message || '加载失败', icon: 'none' })
		} finally {
			loading.value = false
		}
	}
	
	function exportReport() {
		uni.showToast({ title: '导出功能开发中', icon: 'none' })
	}
	
	onMounted(() => {
		loadDriverStatistics()
	})

	async function calculateStatistics() {
		uni.showToast({ title: '正在触发统计...', icon: 'loading' })
		
		try {
			await statisticsApi.calculateAllStatistics()
			uni.hideToast()
			uni.showToast({ title: '统计触发成功', icon: 'success' })
			// 统计完成后刷新数据
			loadDriverStatistics()
		} catch (e) {
			uni.hideToast()
			uni.showToast({ title: '统计触发失败', icon: 'none' })
		}
	}
</script>

<style lang="scss">
	@import '@/styles/admin.scss';
	
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20rpx;
		margin-bottom: 30rpx;
	}
	
	.stat-card {
		background-color: #2a3347;
		border-radius: 16rpx;
		padding: 30rpx;
