		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 10rpx;
	}
	
	.stat-trend {
		font-size: 22rpx;
		
		&.positive {
			color: #34C759;
		}
		
		&.negative {
			color: #FF3B30;
		}
	}
	
	.card-header {
		padding: 25rpx 30rpx;
		border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
	}
	
