				background-color: #2a3347;
				color: rgba(255, 255, 255, 0.7);
				font-size: 22rpx;
				border-radius: 12rpx;
				
				&.active {
					background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
					color: #fff;
				}
			}
		}
	}
	
	.route-card {
		background-color: #2a3347;
		border-radius: 24rpx;
		overflow: hidden;
		
		.route-list {
			.route-item {
				padding: 35rpx;
				border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				
				&:last-child { border-bottom: none; }
				
				.route-left {
					flex: 1;
					
					.route-header {
						display: flex;
						flex-direction: row;
						align-items: center;
						justify-content: space-between;
						margin-bottom: 15rpx;
						
						.route-name {
							font-size: 30rpx;
							font-weight: bold;
							color: #fff;
						}
						
						.route-status {
							padding: 8rpx 20rpx;
							border-radius: 20rpx;
							
							&.enabled { background-color: rgba(52, 199, 89, 0.2); }
							&.disabled { background-color: rgba(142, 142, 147, 0.2); }
							
							.status-text {
								font-size: 22rpx;
								color: #fff;
							}
						}
					}
					
					.route-path {
						display: flex;
						flex-direction: row;
						align-items: center;
						margin-bottom: 15rpx;
						
						.path-text {
							font-size: 26rpx;
							color: rgba(255, 255, 255, 0.8);
						}
						
						.path-arrow {
							margin: 0 15rpx;
							color: #007AFF;
							font-size: 24rpx;
						}
					}
					
					.route-info {
						display: flex;
						flex-direction: row;
						gap: 30rpx;
						
						.info-item {
							font-size: 24rpx;
							color: rgba(255, 255, 255, 0.6);
						}
					}
				}
				
				.route-right {
					.action-buttons {
						display: flex;
						flex-direction: column;
						gap: 15rpx;
						
						.action-btn {
							padding: 12rpx 30rpx;
							background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
							color: #fff;
							font-size: 22rpx;
							border-radius: 10rpx;
							
							&.secondary { background-color: rgba(255, 255, 255, 0.1); }
							&.success { background: linear-gradient(135deg, #34C759 0%, #28a745 100%); }
							&.warning { background: linear-gradient(135deg, #FF9500 0%, #FF6600 100%); }
						}
					}
				}
			}
			
			.empty-state {
				padding: 80rpx;
				text-align: center;
				
				.empty-text {
					color: rgba(255, 255, 255, 0.5);
					font-size: 28rpx;
				}
			}
		}
	}
	
	.pagination {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		gap: 30rpx;
		margin-top: 30rpx;
		
		.page-btn {
			padding: 15rpx 30rpx;
			background-color: #2a3347;
			color: #fff;
			font-size: 24rpx;
			border-radius: 10rpx;
			
			&:disabled { opacity: 0.5; }
		}
		
		.page-info {
			color: rgba(255, 255, 255, 0.7);
			font-size: 24rpx;
		}
	}
	
	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.7);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		
		.modal-content {
			width: 85%;
			max-height: 80%;
			background-color: #1e2536;
			border-radius: 20rpx;
			overflow: hidden;
			
			.modal-header {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				padding: 30rpx;
				border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
				
				.modal-title {
					font-size: 32rpx;
					font-weight: bold;
					color: #fff;
				}
				
				.modal-close {
					font-size: 40rpx;
					color: rgba(255, 255, 255, 0.6);
				}
			}
			
			.modal-body {
				padding: 30rpx;
				max-height: 600rpx;
				overflow-y: auto;
				
				.form-item {
					margin-bottom: 25rpx;
					
					.form-label {
						display: block;
						font-size: 26rpx;
						color: rgba(255, 255, 255, 0.8);
						margin-bottom: 15rpx;
					}
					
					.form-input {
						width: 100%;
						padding: 20rpx;
						background-color: #2a3347;
						border-radius: 10rpx;
						color: #fff;
						font-size: 26rpx;
					}
				}
				
				.form-row {
					display: flex;
					flex-direction: row;
					gap: 20rpx;
					
					.form-item.half {
						flex: 1;
					}
				}
			}
			
			.modal-footer {
				display: flex;
				flex-direction: row;
				gap: 20rpx;
				padding: 30rpx;
				border-top: 1rpx solid rgba(255, 255, 255, 0.1);
				
				.cancel-btn, .confirm-btn {
					flex: 1;
					padding: 20rpx;
					border-radius: 10rpx;
					font-size: 28rpx;
				}
				
