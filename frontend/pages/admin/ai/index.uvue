  flex: 1;
  padding: 20rpx;
}

.message-list {
  padding-bottom: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-icon {
  width: 100%;
  height: 100%;
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  word-break: break-all;
}

.message-item.user .message-content {
  background-color: #667eea;
}

.message-item.assistant .message-content {
  background-color: #ffffff;
}

.message-item.user .message-text {
  color: #ffffff;
}

.message-item.assistant .message-text {
  color: #333333;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.loading .message-content {
  background-color: #e8e8e8;
}

.chat-input-area {
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-action-btn {
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  border-radius: 30rpx;
}

.quick-action-text {
  font-size: 24rpx;
  color: #666666;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn[disabled] {
  opacity: 0.5;
}

.send-btn-text {
  font-size: 28rpx;
  color: #ffffff;
}
</style>
