<template>
	<AdminLayout>
		<view class="page-header">
			<text class="page-title">车辆管理</text>
			<view class="header-actions">
				<button class="primary-btn" @click="showAddModal = true">添加车辆</button>
			</view>
		</view>
		
		<view class="filter-section">
			<view class="search-box">
				<text class="search-icon">🔍</text>
				<input type="text" v-model="searchKeyword" placeholder="搜索车牌号" placeholder-style="color: rgba(255,255,255,0.4)" @confirm="handleSearch" />
			</view>
			<view class="filter-buttons">
				<button class="filter-btn" :class="{'active': currentStatus === null}" @click="filterByStatus(null)">全部</button>
				<button class="filter-btn" :class="{'active': currentStatus === 0}" @click="filterByStatus(0)">空闲</button>
				<button class="filter-btn" :class="{'active': currentStatus === 1}" @click="filterByStatus(1)">运行中</button>
				<button class="filter-btn" :class="{'active': currentStatus === 2}" @click="filterByStatus(2)">维护中</button>
				<button class="filter-btn" :class="{'active': currentStatus === 3}" @click="filterByStatus(3)">故障</button>
			</view>
		</view>
		
		<view class="vehicle-card">
			<view class="vehicle-list">
				<view class="vehicle-item" v-for="(vehicle, index) in vehicleList" :key="vehicle.id">
					<view class="vehicle-left">
						<view class="vehicle-header">
							<text class="vehicle-plate">🚚 {{ vehicle.vehicleNo }}</text>
							<view class="vehicle-status" :class="getStatusClass(vehicle.status)">
								<text class="status-dot"></text>
								<text class="status-text">{{ getStatusText(vehicle.status) }}</text>
							</view>
						</view>
						<text class="vehicle-type">{{ vehicle.brand }} {{ vehicle.model }}</text>
						<view class="vehicle-info">
							<text class="info-item">发动机号：{{ vehicle.engineNumber || '-' }}</text>
							<text class="info-item">车架号：{{ vehicle.vin || '-' }}</text>
						</view>
					</view>
					<view class="vehicle-right">
						<view class="action-buttons">
							<button class="action-btn" @click="viewDetail(vehicle)">详情</button>
							<button class="action-btn secondary" @click="editVehicle(vehicle)">编辑</button>
						</view>
					</view>
				</view>
				
				<view class="empty-state" v-if="vehicleList.length === 0">
					<text class="empty-text">暂无车辆数据</text>
				</view>
			</view>
		</view>
		
		<view class="pagination" v-if="total > pageSize">
			<button class="page-btn" :disabled="currentPage === 1" @click="changePage(currentPage - 1)">上一页</button>
			<text class="page-info">{{ currentPage }} / {{ totalPages }}</text>
			<button class="page-btn" :disabled="currentPage >= totalPages" @click="changePage(currentPage + 1)">下一页</button>
		</view>
		
		<view class="modal-overlay" v-if="showAddModal" @click="showAddModal = false">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">添加车辆</text>
					<text class="modal-close" @click="closeModal">×</text>
				</view>
				<view class="modal-body">
					<view class="form-item">
						<text class="form-label">车牌号 *</text>
						<input type="text" v-model="formData.vehicleNo" class="form-input" placeholder="请输入车牌号" />
					</view>
					<view class="form-item">
						<text class="form-label">车辆类型 *</text>
						<view class="type-selector">
							<view 
								v-for="option in vehicleTypeOptions" 
								:key="option.value" 
								class="type-option"
								:class="{ active: formData.vehicleType === option.value }"
								@click="formData.vehicleType = option.value"
							>
								<text class="type-text">{{ option.label }}</text>
							</view>
						</view>
					</view>
					<view class="form-item">
						<text class="form-label">上传车辆照片</text>
						<view class="upload-area" @click="uploadVehiclePhoto">
							<text class="upload-text" v-if="!vehiclePhotoPreview">点击上传车辆照片</text>
							<image v-else :src="vehiclePhotoPreview" class="preview-image" mode="aspectFit" />
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click="closeModal">取消</button>
					<button class="confirm-btn" @click="submitAddForm">确定</button>
				</view>
			</view>
		</view>
		
		<view class="modal-overlay" v-if="showEditModal" @click="showEditModal = false">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">编辑车辆 - 行驶证上传</text>
					<text class="modal-close" @click="closeEditModal">×</text>
				</view>
				<view class="modal-body">
					<view class="form-item">
						<text class="form-label">车牌号</text>
						<input type="text" v-model="editFormData.vehicleNo" class="form-input" disabled="true" style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);" />
					</view>
					<view class="form-item">
						<text class="form-label">车辆类型</text>
						<view class="type-selector">
							<view 
								v-for="option in vehicleTypeOptions" 
								:key="option.value" 
								class="type-option"
								:class="{ active: editFormData.vehicleType === option.value }"
								@click="editFormData.vehicleType = option.value"
							>
								<text class="type-text">{{ option.label }}</text>
							</view>
						</view>
					</view>
					<view class="form-item">
						<text class="form-label">上传行驶证正面（自动识别）</text>
						<view class="upload-area" @click="uploadLicenseFront">
							<text class="upload-text" v-if="!licenseFrontPreview">点击上传行驶证正面</text>
							<image v-else :src="licenseFrontPreview" class="preview-image" mode="aspectFit" />
						</view>
					</view>
					<view class="form-item">
						<text class="form-label">上传行驶证反面</text>
						<view class="upload-area" @click="uploadLicenseBack">
							<text class="upload-text" v-if="!licenseBackPreview">点击上传行驶证反面</text>
							<image v-else :src="licenseBackPreview" class="preview-image" mode="aspectFit" />
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click="closeEditModal">取消</button>
					<button class="confirm-btn" @click="submitEditForm">保存</button>
				</view>
			</view>
		</view>
		
		<view class="modal-overlay" v-if="showDetailModal" @click="showDetailModal = false">
			<view class="modal-content detail-modal" @click.stop>
				<view class="modal-header">
					<text class="modal-title">车辆详情</text>
					<text class="modal-close" @click="closeDetailModal">×</text>
				</view>
				<scroll-view scroll-y class="modal-body detail-body">
					<view class="detail-section">
						<text class="section-title">基本信息</text>
						<view class="detail-grid">
							<view class="detail-item">
								<text class="detail-label">车牌号</text>
								<text class="detail-value">{{ detailVehicle?.vehicleNo || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">车辆类型</text>
								<text class="detail-value">{{ getVehicleTypeText(detailVehicle?.vehicleType) }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">品牌</text>
								<text class="detail-value">{{ detailVehicle?.brand || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">型号</text>
								<text class="detail-value">{{ detailVehicle?.model || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">品牌型号</text>
								<text class="detail-value">{{ detailVehicle?.brandModel || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">车辆型号</text>
								<text class="detail-value">{{ detailVehicle?.vehicleModel || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">车主</text>
								<text class="detail-value">{{ detailVehicle?.owner || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">地址</text>
								<text class="detail-value">{{ detailVehicle?.address || '-' }}</text>
							</view>
						</view>
					</view>
					
					<view class="detail-section">
						<text class="section-title">车辆参数</text>
						<view class="detail-grid">
							<view class="detail-item">
								<text class="detail-label">发动机号</text>
								<text class="detail-value">{{ detailVehicle?.engineNumber || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">车架号</text>
								<text class="detail-value">{{ detailVehicle?.vin || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">使用性质</text>
								<text class="detail-value">{{ detailVehicle?.useNature || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">注册日期</text>
								<text class="detail-value">{{ detailVehicle?.registerDate || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">发证日期</text>
								<text class="detail-value">{{ detailVehicle?.issueDate || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">核定载人数</text>
								<text class="detail-value">{{ detailVehicle?.seatingCapacity || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">总质量</text>
								<text class="detail-value">{{ detailVehicle?.totalMass || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">整备质量</text>
								<text class="detail-value">{{ detailVehicle?.curbWeight || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">核定载质量</text>
								<text class="detail-value">{{ detailVehicle?.ratedLoad || '-' }}</text>
							</view>
							<view class="detail-item">
								<text class="detail-label">外廓尺寸</text>
								<text class="detail-value">{{ detailVehicle?.dimensions || '-' }}</text>
							</view>
						</view>
					</view>
					
					<view class="detail-section" v-if="detailVehicle?.photoUrl">
						<text class="section-title">车辆照片</text>
						<view class="photo-container">
							<image :src="detailVehicle?.photoUrl" class="detail-photo" mode="aspectFit" @click="previewImage(detailVehicle?.photoUrl)" />
						</view>
					</view>
					
					<view class="detail-section" v-if="detailVehicle?.licenseFrontUrl">
						<text class="section-title">行驶证正面</text>
						<view class="photo-container">
							<image :src="detailVehicle?.licenseFrontUrl" class="detail-photo" mode="aspectFit" @click="previewImage(detailVehicle?.licenseFrontUrl)" />
						</view>
					</view>
					
					<view class="detail-section" v-if="detailVehicle?.licenseBackUrl">
						<text class="section-title">行驶证反面</text>
						<view class="photo-container">
							<image :src="detailVehicle?.licenseBackUrl" class="detail-photo" mode="aspectFit" @click="previewImage(detailVehicle?.licenseBackUrl)" />
						</view>
					</view>
				</scroll-view>
				<view class="modal-footer">
					<button class="confirm-btn" @click="closeDetailModal">关闭</button>
				</view>
			</view>
		</view>
	</AdminLayout>
</template>

<script setup lang="uts">
	import AdminLayout from '../../../components/AdminLayout.uvue'
	import { ref, computed, onMounted } from 'vue'
	import { http } from '@/utils/request.uts'

	type VehicleVO = {
		id: string | null,
		vehicleNo: string,
		vehicleType: string | null,
		brand: string | null,
		model: string | null,
		brandModel: string | null,
		vehicleModel: string | null,
		owner: string | null,
		address: string | null,
		status: number,
		photoUrl: string | null,
		licenseFrontUrl: string | null,
		licenseBackUrl: string | null,
		engineNumber: string | null,
		vin: string | null,
		useNature: string | null,
		registerDate: string | null,
		issueDate: string | null,
		seatingCapacity: number | null,
		totalMass: string | null,
		curbWeight: string | null,
		ratedLoad: string | null,
		dimensions: string | null
	}

	const vehicleList = ref<VehicleVO[]>([])
	const currentPage = ref(1)
	const pageSize = ref(10)
	const total = ref(0)
	const searchKeyword = ref('')
	const currentStatus = ref<number | null>(null)
	const showAddModal = ref(false)
	const showEditModal = ref(false)
	const showDetailModal = ref(false)
	const editingVehicle = ref<VehicleVO | null>(null)
	const detailVehicle = ref<VehicleVO | null>(null)

	const formData = ref({
		vehicleNo: '',
		vehicleType: 1,
		vehiclePhotoPath: ''
	})
	
	const editFormData = ref({
		vehicleNo: '',
		vehicleType: 1,
		licenseFrontPath: '',
		licenseBackPath: ''
	})
	
	const vehicleTypeOptions = [
		{ value: 1, label: '重型卡车' },
		{ value: 2, label: '中型卡车' },
		{ value: 3, label: '轻型卡车' },
		{ value: 4, label: '矿用自卸车' },
		{ value: 5, label: '装载机' },
		{ value: 6, label: '挖掘机' },
		{ value: 7, label: '救援专用车' },
		{ value: 8, label: '其他' }
	]
	
	const vehiclePhotoPreview = ref('')
	const licenseFrontPreview = ref('')
	const licenseBackPreview = ref('')

	const totalPages = computed(() => Math.ceil(total.value / pageSize.value))

	const getStatusClass = (status: number): string => {
		const statusMap: Record<number, string> = {
			0: 'idle',
			1: 'online',
			2: 'maintenance',
			3: 'fault',
			4: 'scrapped'
		}
		return statusMap[status] || 'idle'
	}

	const getStatusText = (status: number): string => {
		const statusMap: Record<number, string> = {
			0: '空闲',
			1: '运行中',
			2: '维护中',
			3: '故障',
			4: '报废'
		}
		return statusMap[status] || '空闲'
	}

	const getVehicleTypeText = (type: number | string | null): string => {
		if (type === null || type === undefined) return '-'
		const typeNum = typeof type === 'string' ? parseInt(type) : type
		const typeMap: Record<number, string> = {
			1: '重型卡车',
			2: '中型卡车',
			3: '轻型卡车',
			4: '矿用自卸车',
			5: '装载机',
			6: '挖掘机',
			7: '救援专用车',
			8: '其他'
		}
		return typeMap[typeNum] || '未知'
	}

	const getVehicleTypeLabel = (type: number): string => {
		const option = vehicleTypeOptions.find(o => o.value === type)
		return option ? option.label : '未知'
	}

	const loadVehicles = async () => {
		try {
			const response = await http.get('/vehicle/page', {
				pageNum: currentPage.value,
				pageSize: pageSize.value,
				vehicleNo: searchKeyword.value,
				status: currentStatus.value
			})
			if (response) {
				vehicleList.value = response as VehicleVO[]
			}
		} catch (error) {
			console.error('加载车辆列表失败:', error)
		}
	}

	const handleSearch = () => {
		currentPage.value = 1
		loadVehicles()
	}

	const filterByStatus = (status: number | null) => {
		currentStatus.value = status
		currentPage.value = 1
		loadVehicles()
	}

	const changePage = (page: number) => {
		currentPage.value = page
		loadVehicles()
	}

	const viewDetail = async (vehicle: VehicleVO) => {
		if (!vehicle.id) return
		try {
			const response = await http.get(`/vehicle/${vehicle.id}`)
			if (response) {
				detailVehicle.value = response as VehicleVO
				showDetailModal.value = true
			}
		} catch (error) {
			console.error('获取车辆详情失败:', error)
			uni.showToast({ title: '获取详情失败', icon: 'none' })
		}
	}

	const closeDetailModal = () => {
		showDetailModal.value = false
		detailVehicle.value = null
	}

	const previewImage = (url: string | null) => {
		if (url) {
			uni.previewImage({
				urls: [url],
				current: url
			})
		}
	}

	const editVehicle = (vehicle: VehicleVO) => {
		editingVehicle.value = vehicle
		const vehicleTypeNum = vehicle.vehicleType ? (typeof vehicle.vehicleType === 'string' ? parseInt(vehicle.vehicleType) : vehicle.vehicleType) : 1
		editFormData.value = {
			vehicleNo: vehicle.vehicleNo,
			vehicleType: vehicleTypeNum,
			licenseFrontPath: '',
			licenseBackPath: ''
		}
		licenseFrontPreview.value = vehicle.licenseFrontUrl || ''
		licenseBackPreview.value = vehicle.licenseBackUrl || ''
		showEditModal.value = true
	}

	const closeModal = () => {
		showAddModal.value = false
		formData.value = {
			vehicleNo: '',
			vehicleType: 1,
			vehiclePhotoPath: ''
		}
		vehiclePhotoPreview.value = ''
	}

	const closeEditModal = () => {
		showEditModal.value = false
		editingVehicle.value = null
		editFormData.value = {
			vehicleNo: '',
			vehicleType: 1,
			licenseFrontPath: '',
			licenseBackPath: ''
		}
		licenseFrontPreview.value = ''
		licenseBackPreview.value = ''
	}

	const uploadVehiclePhoto = () => {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					formData.value.vehiclePhotoPath = tempFile
					vehiclePhotoPreview.value = tempFile
				}
			},
			fail: (err) => {
				console.error('选择车辆照片失败:', err)
			}
		})
	}

	const uploadLicenseFront = () => {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					editFormData.value.licenseFrontPath = tempFile
					licenseFrontPreview.value = tempFile
				}
			},
			fail: (err) => {
				console.error('选择行驶证正面失败:', err)
			}
		})
	}

	const uploadLicenseBack = () => {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					editFormData.value.licenseBackPath = tempFile
					licenseBackPreview.value = tempFile
				}
			},
			fail: (err) => {
				console.error('选择行驶证反面失败:', err)
			}
		})
	}

	const submitAddForm = async () => {
		if (!formData.value.vehicleNo) {
			uni.showToast({ title: '请输入车牌号', icon: 'none' })
			return
		}

		try {
			const token = uni.getStorageSync('token') || ''
			uni.showLoading({ title: '正在添加...' })
			
			if (formData.value.vehiclePhotoPath) {
				await new Promise<void>((resolve, reject) => {
					uni.uploadFile({
						url: 'http://localhost:8080/api/vehicle/create-with-photos',
						filePath: formData.value.vehiclePhotoPath,
						name: 'vehiclePhoto',
						formData: {
							vehicleNo: formData.value.vehicleNo,
							vehicleType: String(formData.value.vehicleType)
						},
						header: {
							'Authorization': `Bearer ${token}`
						},
						success: (res) => {
							const data = JSON.parse(res.data) as { code: number, message: string }
							if (data.code === 200) {
								resolve()
							} else {
								reject(new Error(data.message || '添加失败'))
							}
						},
						fail: (err) => {
							reject(err)
						}
					})
				})
			} else {
				await new Promise<void>((resolve, reject) => {
					uni.request({
						url: 'http://localhost:8080/api/vehicle/create-with-photos',
						method: 'POST',
						data: { 
							vehicleNo: formData.value.vehicleNo,
							vehicleType: formData.value.vehicleType
						},
						header: {
							'Authorization': `Bearer ${token}`,
							'Content-Type': 'application/json'
						},
						success: (res) => {
							const data = res.data as { code: number, message: string }
							if (data.code === 200) {
								resolve()
							} else {
								reject(new Error(data.message || '添加失败'))
							}
						},
						fail: (err) => {
							reject(err)
						}
					})
				})
			}
			
			uni.hideLoading()
			uni.showToast({ title: '添加车辆成功', icon: 'success' })
			closeModal()
			loadVehicles()
		} catch (error) {
			uni.hideLoading()
			console.error('添加车辆失败:', error)
			uni.showToast({ title: '添加车辆失败', icon: 'none' })
		}
	}

	const submitEditForm = async () => {
		if (!editingVehicle.value || !editingVehicle.value.id) {
			uni.showToast({ title: '车辆信息错误', icon: 'none' })
			return
		}

		try {
			const token = uni.getStorageSync('token') || ''
			const vehicleId = editingVehicle.value.id
			uni.showLoading({ title: '正在保存...' })
			
			await new Promise<void>((resolve, reject) => {
				uni.request({
					url: `http://localhost:8080/api/vehicle/${vehicleId}`,
					method: 'PUT',
					data: { 
						vehicleType: editFormData.value.vehicleType
					},
					header: {
						'Authorization': `Bearer ${token}`,
						'Content-Type': 'application/json'
					},
					success: (res) => {
						resolve()
					},
					fail: (err) => {
						resolve()
					}
				})
			})
			
			if (editFormData.value.licenseFrontPath) {
				await new Promise<void>((resolve) => {
					uni.uploadFile({
						url: `http://localhost:8080/api/vehicle/${vehicleId}/license/front`,
						filePath: editFormData.value.licenseFrontPath,
						name: 'file',
						header: {
							'Authorization': `Bearer ${token}`
						},
						success: () => resolve(),
						fail: () => resolve()
					})
				})
			}
			
			if (editFormData.value.licenseBackPath) {
				await new Promise<void>((resolve) => {
					uni.uploadFile({
						url: `http://localhost:8080/api/vehicle/${vehicleId}/license/back`,
						filePath: editFormData.value.licenseBackPath,
						name: 'file',
						header: {
							'Authorization': `Bearer ${token}`
						},
						success: () => resolve(),
						fail: () => resolve()
					})
				})
			}
			
			uni.hideLoading()
			uni.showToast({ title: '保存成功', icon: 'success' })
			closeEditModal()
			loadVehicles()
		} catch (error) {
			uni.hideLoading()
			console.error('保存失败:', error)
			uni.showToast({ title: '保存失败', icon: 'none' })
		}
	}

	onMounted(() => {
		loadVehicles()
	})
</script>

