			font-size: 36rpx;
			font-weight: bold;
			color: #fff;
		}
		
		.header-actions {
			.primary-btn {
				padding: 20rpx 40rpx;
				background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
				color: #fff;
				font-size: 24rpx;
				font-weight: 500;
				border-radius: 12rpx;
			}
		}
	}
	
	.filter-section {
		display: flex;
		flex-direction: row;
		gap: 30rpx;
		margin-bottom: 30rpx;
		
		.search-box {
			flex: 1;
			display: flex;
			flex-direction: row;
			align-items: center;
			background-color: #2a3347;
			border-radius: 16rpx;
			padding: 20rpx 30rpx;
			
			.search-icon {
				font-size: 28rpx;
				margin-right: 15rpx;
				opacity: 0.6;
			}
			
			input {
				flex: 1;
				font-size: 26rpx;
				color: #fff;
			}
		}
		
		.filter-buttons {
			display: flex;
			flex-direction: row;
			gap: 15rpx;
			
			.filter-btn {
				padding: 15rpx 25rpx;
				background-color: #2a3347;
				color: rgba(255, 255, 255, 0.7);
				font-size: 22rpx;
				border-radius: 12rpx;
				
				&.active {
					background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
					color: #fff;
				}
			}
		}
	}
	
	.vehicle-card {
		background-color: #2a3347;
		border-radius: 24rpx;
		overflow: hidden;
		
		.vehicle-list {
			.vehicle-item {
				padding: 35rpx;
				border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				
				&:last-child {
					border-bottom: none;
				}
				
				.vehicle-left {
					flex: 1;
					
					.vehicle-header {
						display: flex;
						flex-direction: row;
						align-items: center;
						justify-content: space-between;
						margin-bottom: 12rpx;
						
						.vehicle-plate {
							font-size: 32rpx;
							font-weight: bold;
							color: #fff;
						}
						
						.vehicle-status {
							display: flex;
							flex-direction: row;
							align-items: center;
							padding: 8rpx 20rpx;
							border-radius: 20rpx;
							
							&.idle { background-color: rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.5); }
							&.online { background-color: rgba(52, 199, 89, 0.2); color: #34C759; }
							&.maintenance { background-color: rgba(255, 149, 0, 0.2); color: #FF9500; }
							&.fault { background-color: rgba(255, 59, 48, 0.2); color: #FF3B30; }
							&.scrapped { background-color: rgba(142, 142, 147, 0.2); color: #8E8E93; }
							
							.status-dot {
								width: 12rpx;
								height: 12rpx;
								border-radius: 50%;
								background-color: currentColor;
								margin-right: 10rpx;
							}
							
							.status-text {
								font-size: 22rpx;
							}
						}
					}
					
					.vehicle-type {
						font-size: 24rpx;
						color: rgba(255, 255, 255, 0.7);
						margin-bottom: 8rpx;
						display: block;
					}
					
					.vehicle-driver {
						font-size: 22rpx;
						color: rgba(255, 255, 255, 0.6);
						margin-bottom: 8rpx;
						display: block;
					}
					
					.vehicle-info {
						display: flex;
						flex-direction: column;
						gap: 6rpx;
						
						.info-item {
							font-size: 20rpx;
							color: rgba(255, 255, 255, 0.5);
						}
					}
				}
				
				.vehicle-right {
					.action-buttons {
						display: flex;
						flex-direction: column;
						gap: 15rpx;
						
						.action-btn {
							padding: 12rpx 30rpx;
							background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
							color: #fff;
							font-size: 22rpx;
							border-radius: 10rpx;
							
							&.secondary {
								background-color: rgba(255, 255, 255, 0.1);
							}
							
							&.warning {
								background: linear-gradient(135deg, #FF9500 0%, #FF6600 100%);
							}
						}
					}
				}
			}
			
			.empty-state {
				padding: 80rpx;
				text-align: center;
				
				.empty-text {
					color: rgba(255, 255, 255, 0.5);
					font-size: 28rpx;
				}
			}
		}
	}
	
	.pagination {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		gap: 30rpx;
		margin-top: 30rpx;
		
		.page-btn {
			padding: 15rpx 30rpx;
			background-color: #2a3347;
			color: #fff;
			font-size: 24rpx;
			border-radius: 10rpx;
			
			&:disabled {
				opacity: 0.5;
			}
		}
		
		.page-info {
			color: rgba(255, 255, 255, 0.7);
			font-size: 24rpx;
		}
	}
	
	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.7);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		
		.modal-content {
			width: 80%;
			max-height: 80%;
			background-color: #1e2536;
			border-radius: 20rpx;
			overflow: hidden;
			
			.modal-header {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				padding: 30rpx;
				border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
				
				.modal-title {
					font-size: 32rpx;
					font-weight: bold;
					color: #fff;
				}
				
				.modal-close {
					font-size: 40rpx;
					color: rgba(255, 255, 255, 0.6);
				}
			}
			
			.modal-body {
				padding: 30rpx;
				max-height: 600rpx;
				overflow-y: auto;
				
				.form-item {
					margin-bottom: 25rpx;
					
					.form-label {
						display: block;
						font-size: 26rpx;
						color: rgba(255, 255, 255, 0.8);
						margin-bottom: 15rpx;
					}
					
					.form-input {
						width: 100%;
						padding: 20rpx;
						background-color: #2a3347;
						border-radius: 10rpx;
						color: #fff;
						font-size: 26rpx;
					}
					
					.upload-area {
						width: 100%;
						height: 200rpx;
						background-color: #2a3347;
						border-radius: 10rpx;
						border: 2rpx dashed rgba(255, 255, 255, 0.2);
						display: flex;
						justify-content: center;
						align-items: center;
						
						.upload-text {
							color: rgba(255, 255, 255, 0.5);
							font-size: 26rpx;
						}
						
						.preview-image {
							width: 100%;
							height: 100%;
						}
					}
				}
			}
			
			.modal-footer {
				display: flex;
				flex-direction: row;
				gap: 20rpx;
				padding: 30rpx;
				border-top: 1rpx solid rgba(255, 255, 255, 0.1);
				
				.cancel-btn, .confirm-btn {
					flex: 1;
					padding: 20rpx;
					border-radius: 10rpx;
					font-size: 28rpx;
				}
				
				.cancel-btn {
					background-color: #2a3347;
					color: rgba(255, 255, 255, 0.8);
				}
				
				.confirm-btn {
					background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
					color: #fff;
				}
			}
		}
	}
</style>
