<template>
	<AdminLayout>
		<view class="page-header">
			<text class="page-title">预警管理</text>
			<view class="header-actions">
				<button class="primary-btn" @click="showRuleModal = true">预警规则</button>
			</view>
		</view>
		
		<view class="stats-section">
			<view class="stat-card pending">
				<text class="stat-value">{{ statistics.pendingCount }}</text>
				<text class="stat-label">待处理</text>
			</view>
			<view class="stat-card processing">
				<text class="stat-value">{{ statistics.processingCount }}</text>
				<text class="stat-label">处理中</text>
			</view>
			<view class="stat-card resolved">
				<text class="stat-value">{{ statistics.resolvedCount }}</text>
				<text class="stat-label">已解决</text>
			</view>
			<view class="stat-card high">
				<text class="stat-value">{{ statistics.highLevelCount }}</text>
				<text class="stat-label">高危预警</text>
			</view>
		</view>
		
		<view class="filter-section">
			<view class="search-box">
				<text class="search-icon">🔍</text>
				<input type="text" v-model="searchKeyword" placeholder="搜索预警编号" placeholder-style="color: rgba(255,255,255,0.4)" @confirm="handleSearch" />
			</view>
			<view class="filter-buttons">
				<button class="filter-btn" :class="{'active': currentStatus === null}" @click="filterByStatus(null)">全部</button>
				<button class="filter-btn" :class="{'active': currentStatus === 0}" @click="filterByStatus(0)">待处理</button>
				<button class="filter-btn" :class="{'active': currentStatus === 1}" @click="filterByStatus(1)">处理中</button>
				<button class="filter-btn" :class="{'active': currentStatus === 2}" @click="filterByStatus(2)">已解决</button>
			</view>
			<view class="filter-buttons">
				<button class="filter-btn" :class="{'active': currentLevel === null}" @click="filterByLevel(null)">全部级别</button>
				<button class="filter-btn level-low" :class="{'active': currentLevel === 1}" @click="filterByLevel(1)">低危</button>
				<button class="filter-btn level-medium" :class="{'active': currentLevel === 2}" @click="filterByLevel(2)">中危</button>
				<button class="filter-btn level-high" :class="{'active': currentLevel === 3}" @click="filterByLevel(3)">高危</button>
			</view>
		</view>
		
		<view class="warning-card">
			<view class="warning-list">
				<view class="warning-item" v-for="(warning, index) in warningList" :key="warning.id">
					<view class="warning-left">
						<view class="warning-header">
							<text class="warning-no">⚠️ {{ warning.warningNo }}</text>
							<view class="warning-badges">
								<view class="warning-level" :class="getLevelClass(warning.warningLevel)">
									<text>{{ warning.warningLevelName }}</text>
								</view>
								<view class="warning-status" :class="getStatusClass(warning.status)">
									<text class="status-dot"></text>
									<text class="status-text">{{ warning.statusName }}</text>
								</view>
							</view>
						</view>
						<text class="warning-type">类型：{{ warning.warningTypeName }}</text>
						<text class="warning-content">{{ warning.warningContent }}</text>
						<view class="warning-info">
							<text class="info-item">车辆：{{ warning.vehicleNo || '-' }}</text>
							<text class="info-item">司机：{{ warning.driverName || '-' }}</text>
						</view>
						<text class="warning-time">时间：{{ warning.warningTime }}</text>
					</view>
					<view class="warning-right">
						<view class="action-buttons" v-if="warning.status === 0 || warning.status === 1">
							<button class="action-btn primary" @click="showHandleModal(warning)">处理</button>
							<button class="action-btn secondary" v-if="warning.status === 0" @click="handleIgnore(warning)">忽略</button>
						</view>
						<view class="action-buttons" v-else>
							<button class="action-btn view" @click="viewDetail(warning)">详情</button>
						</view>
					</view>
				</view>
				
				<view class="empty-state" v-if="warningList.length === 0">
					<text class="empty-text">暂无预警数据</text>
				</view>
			</view>
		</view>
		
		<view class="pagination" v-if="total > pageSize">
			<button class="page-btn" :disabled="currentPage === 1" @click="changePage(currentPage - 1)">上一页</button>
			<text class="page-info">{{ currentPage }} / {{ totalPages }}</text>
			<button class="page-btn" :disabled="currentPage >= totalPages" @click="changePage(currentPage + 1)">下一页</button>
		</view>
		
		<view class="modal-overlay" v-if="showHandleModalFlag" @click="closeHandleModal">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">处理预警</text>
					<text class="modal-close" @click="closeHandleModal">×</text>
				</view>
				<view class="modal-body">
					<view class="form-item">
						<text class="form-label">预警编号</text>
						<text class="form-value">{{ selectedWarning?.warningNo }}</text>
					</view>
					<view class="form-item">
						<text class="form-label">预警内容</text>
						<text class="form-value">{{ selectedWarning?.warningContent }}</text>
					</view>
					<view class="form-item">
						<text class="form-label">处理结果 *</text>
						<textarea v-model="handleResult" class="form-textarea" placeholder="请输入处理结果" />
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click="closeHandleModal">取消</button>
					<button class="confirm-btn" @click="submitHandle">确认处理</button>
				</view>
			</view>
		</view>
		
		<view class="modal-overlay" v-if="showRuleModal" @click="showRuleModal = false">
			<view class="modal-content rule-modal" @click.stop>
				<view class="modal-header">
					<text class="modal-title">预警规则</text>
					<text class="modal-close" @click="showRuleModal = false">×</text>
				</view>
				<view class="modal-body">
					<view class="rule-list">
						<view class="rule-item" v-for="rule in ruleList" :key="rule.id">
							<view class="rule-info">
								<text class="rule-name">{{ rule.ruleName }}</text>
								<text class="rule-desc">{{ rule.description }}</text>
								<text class="rule-threshold">阈值：{{ rule.thresholdValue || '-' }}</text>
							</view>
							<view class="rule-actions">
								<view class="rule-status" :class="rule.status === 1 ? 'enabled' : 'disabled'">
									<text>{{ rule.status === 1 ? '启用' : '禁用' }}</text>
								</view>
								<switch :checked="rule.status === 1" @change="toggleRuleStatus(rule)" color="#007AFF" />
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
	</AdminLayout>
</template>

<script setup lang="uts">
	import AdminLayout from '../../../components/AdminLayout.uvue'
	import { ref, computed, onMounted } from 'vue'
	import { 
		getWarningRecordPage, 
		getWarningStatistics, 
		handleWarningRecord, 
		ignoreWarningRecord,
		getWarningRuleList,
		enableWarningRule,
		disableWarningRule
	} from '@/api/warning.uts'
	import type { WarningRecord, WarningStatistics, WarningRule } from '@/api/warning.uts'

	const warningList = ref<WarningRecord[]>([])
	const currentPage = ref(1)
	const pageSize = ref(10)
	const total = ref(0)
	const searchKeyword = ref('')
	const currentStatus = ref<number | null>(null)
	const currentLevel = ref<number | null>(null)
	
	const showHandleModalFlag = ref(false)
	const selectedWarning = ref<WarningRecord | null>(null)
	const handleResult = ref('')
	
	const showRuleModal = ref(false)
	const ruleList = ref<WarningRule[]>([])
	
	const statistics = ref<WarningStatistics>({
		totalWarnings: 0,
		pendingCount: 0,
		processingCount: 0,
		resolvedCount: 0,
		ignoredCount: 0,
		highLevelCount: 0,
		mediumLevelCount: 0,
		lowLevelCount: 0,
		typeDistribution: [],
		levelDistribution: new Map<string, number>(),
		trendData: []
	})

	const totalPages = computed(() => Math.ceil(total.value / pageSize.value))

	const getLevelClass = (level: number): string => {
		const levelMap: Record<number, string> = {
			1: 'low',
			2: 'medium',
			3: 'high'
		}
		return levelMap[level] || 'low'
	}

	const getStatusClass = (status: number): string => {
		const statusMap: Record<number, string> = {
			0: 'pending',
			1: 'processing',
			2: 'resolved',
			3: 'ignored'
		}
		return statusMap[status] || 'pending'
	}

	const fetchWarningList = async () => {
		try {
			const res = await getWarningRecordPage({
				page: currentPage.value,
				size: pageSize.value,
				status: currentStatus.value !== null ? currentStatus.value : undefined,
				warningLevel: currentLevel.value !== null ? currentLevel.value : undefined
			})
			if (res) {
				warningList.value = res.list || []
				total.value = res.total || 0
			}
		} catch (e) {
			console.error('获取预警列表失败', e)
		}
	}

	const fetchStatistics = async () => {
		try {
			const today = new Date()
			const startDate = new Date(today.getFullYear(), today.getMonth(), 1)
			const res = await getWarningStatistics(
				startDate.toISOString().split('T')[0],
				today.toISOString().split('T')[0]
			)
			if (res) {
				statistics.value = res
			}
		} catch (e) {
			console.error('获取统计数据失败', e)
		}
	}

	const fetchRuleList = async () => {
		try {
			const res = await getWarningRuleList({})
			if (res) {
				ruleList.value = res
			}
		} catch (e) {
			console.error('获取规则列表失败', e)
		}
	}

	const handleSearch = () => {
		currentPage.value = 1
		fetchWarningList()
	}

	const filterByStatus = (status: number | null) => {
		currentStatus.value = status
		currentPage.value = 1
		fetchWarningList()
	}

	const filterByLevel = (level: number | null) => {
		currentLevel.value = level
		currentPage.value = 1
		fetchWarningList()
	}

	const changePage = (page: number) => {
		currentPage.value = page
		fetchWarningList()
	}

	const showHandleModal = (warning: WarningRecord) => {
		selectedWarning.value = warning
		handleResult.value = ''
		showHandleModalFlag.value = true
	}

	const closeHandleModal = () => {
		showHandleModalFlag.value = false
		selectedWarning.value = null
		handleResult.value = ''
	}

	const submitHandle = async () => {
		if (!handleResult.value) {
			uni.showToast({ title: '请输入处理结果', icon: 'none' })
			return
		}
		if (!selectedWarning.value) return
		
		try {
			await handleWarningRecord(selectedWarning.value.id, {
				handleResult: handleResult.value
			})
			uni.showToast({ title: '处理成功', icon: 'success' })
			closeHandleModal()
			fetchWarningList()
			fetchStatistics()
		} catch (e) {
			uni.showToast({ title: '处理失败', icon: 'none' })
		}
	}

	const handleIgnore = async (warning: WarningRecord) => {
		uni.showModal({
			title: '确认忽略',
			content: '确定要忽略此预警吗？',
			success: async (res) => {
				if (res.confirm) {
					try {
						await ignoreWarningRecord(warning.id)
						uni.showToast({ title: '已忽略', icon: 'success' })
						fetchWarningList()
						fetchStatistics()
					} catch (e) {
						uni.showToast({ title: '操作失败', icon: 'none' })
					}
				}
			}
		})
	}

	const viewDetail = (warning: WarningRecord) => {
		uni.showModal({
			title: '预警详情',
			content: `编号：${warning.warningNo}\n类型：${warning.warningTypeName}\n级别：${warning.warningLevelName}\n内容：${warning.warningContent}\n处理结果：${warning.handleResult || '无'}`,
			showCancel: false
		})
	}

	const toggleRuleStatus = async (rule: WarningRule) => {
		try {
			if (rule.status === 1) {
				await disableWarningRule(rule.id)
				rule.status = 0
			} else {
				await enableWarningRule(rule.id)
				rule.status = 1
			}
			uni.showToast({ title: '操作成功', icon: 'success' })
		} catch (e) {
			uni.showToast({ title: '操作失败', icon: 'none' })
		}
	}

	onMounted(() => {
		fetchWarningList()
		fetchStatistics()
		fetchRuleList()
	})
</script>

