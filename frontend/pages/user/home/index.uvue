	.user-home-container {
		min-height: 100vh;
		background-color: #f5f7fa;
	}
	
	.top-navbar {
		background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
		padding: 40rpx 30rpx;
		padding-top: 80rpx;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
	}
	
	.user-info {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 20rpx;
		
		.avatar {
			width: 80rpx;
			height: 80rpx;
			border-radius: 50%;
			border: 4rpx solid rgba(255, 255, 255, 0.3);
		}
		
		.user-text {
			display: flex;
			flex-direction: column;
			gap: 6rpx;
			
