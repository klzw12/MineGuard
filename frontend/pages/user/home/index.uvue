		font-weight: bold;
	}
	
	.status-indicator.online {
		background-color: $uni-color-success;
		color: $uni-text-color-inverse;
	}
	
	.status-details {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20rpx;
		margin-bottom: 30rpx;
	}
	
	.status-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 20rpx;
		background-color: $uni-bg-color-grey;
		border-radius: $uni-border-radius-xl;
		min-width: 120rpx;
	}
	
	.status-icon {
		font-size: 36rpx;
		margin-bottom: 10rpx;
	}
	
	.status-label {
		font-size: 20rpx;
		color: $uni-text-color-grey;
		margin-bottom: 5rpx;
	}
	
	.status-value {
		font-size: 22rpx;
		font-weight: bold;
		color: $uni-text-color;
	}
	
	.view-details-btn {
		display: block;
		text-align: center;
		padding: 20rpx;
		background-color: $uni-bg-color-grey;
		color: $uni-color-success;
		font-size: 24rpx;
		font-weight: bold;
		border-radius: $uni-border-radius-lg;
	}
	
	/* 响应式设计 */
	@media (min-width: 768px) {
		.home-container {
			max-width: 1200rpx;
			margin: 0 auto;
			padding: 40rpx;
		}
		
		.overview-cards {
			grid-template-columns: repeat(3, 1fr);
		}
		
		.actions-grid {
			grid-template-columns: repeat(4, 1fr);
		}
		
		.status-details {
			grid-template-columns: repeat(3, 1fr);
		}
		
		/* 调整卡片和容器的间距 */
		.task-overview-section,
		.quick-actions-section,
		.current-task-section,
		.vehicle-status-section {
			margin-bottom: 50rpx;
		}
		
		/* 调整字体大小 */
		.section-title {
			font-size: 32rpx;
		}
		
		.welcome-text {
			font-size: 36rpx;
		}
