		box-shadow: $uni-shadow-sm;
	}
	
	.status-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 25rpx;
		padding-bottom: 20rpx;
		border-bottom: 1rpx solid $uni-border-color;
	}
	
	.vehicle-number {
		font-size: 26rpx;
		font-weight: bold;
		color: $uni-text-color;
	}
	
	.status-indicator {
		padding: 8rpx 20rpx;
		border-radius: 20rpx;
