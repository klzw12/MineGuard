			right: -5rpx;
			min-width: 32rpx;
			height: 32rpx;
			background-color: #e74c3c;
			border-radius: 16rpx;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 0 8rpx;
			
			text {
				font-size: 20rpx;
				color: #fff;
			}
		}
	}
	
	.content-area {
		padding: 30rpx;
	}
	
	.time-filter {
		display: flex;
		flex-direction: row;
		background-color: #fff;
		border-radius: 16rpx;
		padding: 8rpx;
		margin-bottom: 30rpx;
		
		.filter-item {
			flex: 1;
			padding: 16rpx 0;
			text-align: center;
			border-radius: 12rpx;
			
			text {
				font-size: 26rpx;
				color: #666;
			}
			
			&.active {
				background-color: #2c3e50;
				
				text {
					color: #fff;
					font-weight: 500;
				}
			}
		}
	}
	
	.stats-card {
		background-color: #fff;
		border-radius: 20rpx;
		padding: 30rpx;
		margin-bottom: 25rpx;
		box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
		
		.card-header {
			margin-bottom: 25rpx;
			
			.card-title {
				font-size: 30rpx;
				font-weight: bold;
				color: #2c3e50;
			}
		}
	}
	
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20rpx;
		
		.stat-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			padding: 20rpx 0;
			
			.stat-value {
				font-size: 36rpx;
				font-weight: bold;
				color: #2c3e50;
				margin-bottom: 10rpx;
				
				&.warning {
					color: #e74c3c;
				}
				
				&.highlight {
					color: #27ae60;
				}
			}
			
			.stat-label {
				font-size: 22rpx;
				color: #7f8c8d;
			}
		}
	}
	
	.attendance-rate {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 20rpx;
		margin-top: 20rpx;
		padding-top: 20rpx;
		border-top: 1rpx solid #f0f0f0;
		
		.rate-label {
			font-size: 24rpx;
			color: #666;
			white-space: nowrap;
		}
		
		.rate-bar {
			flex: 1;
			height: 16rpx;
			background-color: #ecf0f1;
			border-radius: 8rpx;
			overflow: hidden;
			
			.rate-fill {
				height: 100%;
				background: linear-gradient(90deg, #27ae60 0%, #2ecc71 100%);
				border-radius: 8rpx;
				transition: width 0.3s ease;
			}
		}
		
		.rate-value {
			font-size: 26rpx;
			font-weight: bold;
			color: #27ae60;
			min-width: 80rpx;
			text-align: right;
		}
	}
	
	.warning-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 15rpx;
		
		.warning-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			padding: 20rpx 10rpx;
			background-color: #fef9f3;
			border-radius: 12rpx;
			
			.warning-icon {
				font-size: 32rpx;
				margin-bottom: 10rpx;
			}
			
			.warning-count {
				font-size: 32rpx;
				font-weight: bold;
				color: #e74c3c;
				margin-bottom: 6rpx;
			}
			
			.warning-label {
				font-size: 20rpx;
				color: #7f8c8d;
			}
		}
	}
	
	.quick-actions {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20rpx;
		margin-top: 10rpx;
		
		.action-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 15rpx;
			
			.action-icon {
				width: 90rpx;
				height: 90rpx;
				border-radius: 20rpx;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 36rpx;
				
				&.green {
					background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
				}
				
				&.blue {
					background: linear-gradient(135deg, #2980b9 0%, #3498db 100%);
				}
				
				&.orange {
					background: linear-gradient(135deg, #d35400 0%, #e67e22 100%);
				}
				
				&.purple {
					background: linear-gradient(135deg, #8e44ad 0%, #9b59b6 100%);
				}
			}
			
			.action-text {
				font-size: 24rpx;
				color: #2c3e50;
			}
		}
	}
</style>
