<template>
	<view class="user-home-container">
		<view class="top-navbar">
			<view class="user-info">
				<image class="avatar" :src="userInfo?.avatarUrl || '/static/default-avatar.png'" mode="aspectFill"></image>
				<view class="user-text">
					<text class="greeting">{{ getGreeting() }}</text>
					<text class="username">{{ userInfo?.realName || userInfo?.username || '用户' }}</text>
				</view>
			</view>
			<view class="notification-btn" @click="goToMessages">
				<text>🔔</text>
				<view class="badge" v-if="unreadCount > 0">
					<text>{{ unreadCount > 99 ? '99+' : unreadCount }}</text>
				</view>
			</view>
		</view>
		
		<view class="content-area">
			<!-- 时间范围选择 -->
			<view class="time-filter">
				<view 
					class="filter-item" 
					:class="{ active: timeRange === 'day' }"
					@click="setTimeRange('day')"
				>
					<text>今日</text>
				</view>
				<view 
					class="filter-item" 
					:class="{ active: timeRange === 'week' }"
					@click="setTimeRange('week')"
				>
					<text>本周</text>
				</view>
				<view 
					class="filter-item" 
					:class="{ active: timeRange === 'month' }"
					@click="setTimeRange('month')"
				>
					<text>本月</text>
				</view>
			</view>
			
			<!-- 出勤统计卡片 -->
			<view class="stats-card attendance-card">
				<view class="card-header">
					<text class="card-title">📊 出勤统计</text>
				</view>
				<view class="stats-grid">
					<view class="stat-item">
						<text class="stat-value">{{ attendanceStats.actualAttendanceDays || 0 }}</text>
						<text class="stat-label">出勤天数</text>
					</view>
					<view class="stat-item">
						<text class="stat-value">{{ attendanceStats.attendanceHours || 0 }}</text>
						<text class="stat-label">出勤时长(h)</text>
					</view>
					<view class="stat-item">
						<text class="stat-value warning">{{ attendanceStats.lateTimes || 0 }}</text>
						<text class="stat-label">迟到次数</text>
					</view>
					<view class="stat-item">
						<text class="stat-value warning">{{ attendanceStats.earlyLeaveTimes || 0 }}</text>
						<text class="stat-label">早退次数</text>
					</view>
				</view>
				<view class="attendance-rate">
					<text class="rate-label">出勤率</text>
					<view class="rate-bar">
						<view class="rate-fill" :style="{ width: (attendanceStats.attendanceRate || 0) + '%' }"></view>
					</view>
					<text class="rate-value">{{ (attendanceStats.attendanceRate || 0).toFixed(1) }}%</text>
				</view>
			</view>
			
			<!-- 行程统计卡片 -->
			<view class="stats-card trip-card">
				<view class="card-header">
					<text class="card-title">🚗 行程统计</text>
				</view>
				<view class="stats-grid">
					<view class="stat-item">
						<text class="stat-value">{{ tripStats.tripCount || 0 }}</text>
						<text class="stat-label">行程次数</text>
					</view>
					<view class="stat-item">
						<text class="stat-value">{{ (tripStats.totalDistance || 0).toFixed(1) }}</text>
						<text class="stat-label">行驶里程(km)</text>
					</view>
					<view class="stat-item">
						<text class="stat-value">{{ (tripStats.cargoWeight || 0).toFixed(1) }}</text>
						<text class="stat-label">运输吨位(t)</text>
					</view>
					<view class="stat-item">
						<text class="stat-value highlight">{{ (tripStats.performanceScore || 0).toFixed(1) }}</text>
						<text class="stat-label">绩效评分</text>
					</view>
				</view>
			</view>
			
			<!-- 违规预警卡片 -->
			<view class="stats-card warning-card">
				<view class="card-header">
					<text class="card-title">⚠️ 违规预警</text>
				</view>
				<view class="warning-grid">
					<view class="warning-item">
						<text class="warning-icon">🚨</text>
						<text class="warning-count">{{ tripStats.warningCount || 0 }}</text>
						<text class="warning-label">预警次数</text>
					</view>
					<view class="warning-item">
						<text class="warning-icon">📋</text>
						<text class="warning-count">{{ tripStats.violationCount || 0 }}</text>
						<text class="warning-label">违章次数</text>
					</view>
					<view class="warning-item">
						<text class="warning-icon">⚡</text>
						<text class="warning-count">{{ tripStats.overSpeedCount || 0 }}</text>
						<text class="warning-label">超速次数</text>
					</view>
					<view class="warning-item">
						<text class="warning-icon">🔀</text>
						<text class="warning-count">{{ tripStats.routeDeviationCount || 0 }}</text>
						<text class="warning-label">路线偏离</text>
					</view>
				</view>
			</view>
			
			<!-- 快捷操作 -->
			<view class="quick-actions">
				<view class="action-item" @click="goToCheckIn">
					<view class="action-icon green">
						<text>📍</text>
					</view>
					<text class="action-text">打卡签到</text>
				</view>
				<view class="action-item" @click="goToTripList">
					<view class="action-icon blue">
						<text>📋</text>
					</view>
					<text class="action-text">行程记录</text>
				</view>
				<view class="action-item" @click="goToAttendanceList">
					<view class="action-icon orange">
						<text>📅</text>
					</view>
					<text class="action-text">考勤记录</text>
				</view>
				<view class="action-item" @click="goToProfile">
					<view class="action-icon purple">
						<text>👤</text>
					</view>
					<text class="action-text">个人中心</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted, computed } from 'vue'
	import { statisticsApi, DriverStatisticsVO } from '@/api/statistics.uts'
	import { getAttendanceStatistics, AttendanceStatisticsVO } from '@/api/attendance.uts'
	import { getToken } from '@/utils/request.uts'
	
	type UserInfo = {
		id: string
		username: string
		realName: string
		avatarUrl: string
	}
	
	const userInfo = ref<UserInfo | null>(null)
	const timeRange = ref<'day' | 'week' | 'month'>('day')
	const unreadCount = ref(0)
	
	const attendanceStats = ref<AttendanceStatisticsVO>({
		userId: '',
		userName: '',
		month: '',
		totalAttendanceDays: 0,
		actualAttendanceDays: 0,
		normalDays: 0,
		lateTimes: 0,
		earlyLeaveTimes: 0,
		absentDays: 0,
		leaveDays: 0,
		attendanceRate: 0,
		attendanceDays: 0,
		attendanceHours: 0,
		lateCount: 0,
		earlyLeaveCount: 0
	})
	
	const tripStats = ref<DriverStatisticsVO>({
		id: 0,
		userId: 0,
		userName: '',
		statisticsDate: '',
		attendanceDays: 0,
		attendanceHours: 0,
		tripCount: 0,
		totalDistance: 0,
		cargoWeight: 0,
		lateCount: 0,
		earlyLeaveCount: 0,
		warningCount: 0,
		violationCount: 0,
		overSpeedCount: 0,
		routeDeviationCount: 0,
		performanceScore: 0
	})
	
	function getGreeting(): string {
		const hour = new Date().getHours()
		if (hour < 6) return '夜深了'
		if (hour < 9) return '早上好'
		if (hour < 12) return '上午好'
		if (hour < 14) return '中午好'
		if (hour < 18) return '下午好'
		if (hour < 22) return '晚上好'
		return '夜深了'
	}
	
	function setTimeRange(range: 'day' | 'week' | 'month') {
		timeRange.value = range
		loadStatistics()
	}
	
	function getDateRange(): { startDate: string, endDate: string } {
		const now = new Date()
		const year = now.getFullYear()
		const month = String(now.getMonth() + 1).padStart(2, '0')
		const day = String(now.getDate()).padStart(2, '0')
		const today = `${year}-${month}-${day}`
		
		if (timeRange.value === 'day') {
			return { startDate: today, endDate: today }
		} else if (timeRange.value === 'week') {
			const weekStart = new Date(now)
			weekStart.setDate(now.getDate() - now.getDay() + 1)
			const ws = `${weekStart.getFullYear()}-${String(weekStart.getMonth() + 1).padStart(2, '0')}-${String(weekStart.getDate()).padStart(2, '0')}`
			return { startDate: ws, endDate: today }
		} else {
			const monthStart = `${year}-${month}-01`
			return { startDate: monthStart, endDate: today }
		}
	}
	
	async function loadStatistics() {
		const userId = userInfo.value?.id
		if (!userId) return
		
		const dateRange = getDateRange()
		
		// 加载出勤统计
		try {
			const yearMonth = dateRange.startDate.substring(0, 7)
			const attendanceResult = await getAttendanceStatistics(yearMonth)
			if (attendanceResult) {
				attendanceStats.value = attendanceResult
			}
		} catch (e) {
			console.error('加载出勤统计失败', e)
		}
		
		// 加载行程统计
		try {
			const driverResult = await statisticsApi.getDriverStatistics({
				userId: userId,
				startDate: dateRange.startDate,
				endDate: dateRange.endDate
			})
			if (driverResult && driverResult.length > 0) {
				// 合并多天的数据
				let totalTripCount = 0
				let totalDistance = 0
				let totalCargoWeight = 0
				let totalAttendanceDays = 0
				let totalAttendanceHours = 0
				let totalLateCount = 0
				let totalEarlyLeaveCount = 0
				let totalWarningCount = 0
				let totalViolationCount = 0
				let totalOverSpeedCount = 0
				let totalRouteDeviationCount = 0
				let totalPerformanceScore = 0
				
				driverResult.forEach(item => {
					totalTripCount += item.tripCount || 0
					totalDistance += item.totalDistance || 0
					totalCargoWeight += item.cargoWeight || 0
					totalAttendanceDays += item.attendanceDays || 0
					totalAttendanceHours += item.attendanceHours || 0
					totalLateCount += item.lateCount || 0
					totalEarlyLeaveCount += item.earlyLeaveCount || 0
					totalWarningCount += item.warningCount || 0
					totalViolationCount += item.violationCount || 0
					totalOverSpeedCount += item.overSpeedCount || 0
					totalRouteDeviationCount += item.routeDeviationCount || 0
					totalPerformanceScore += item.performanceScore || 0
				})
				
				tripStats.value = {
					id: 0,
					userId: parseInt(userId),
					userName: userInfo.value?.realName || '',
					statisticsDate: dateRange.startDate,
					attendanceDays: totalAttendanceDays,
					attendanceHours: totalAttendanceHours,
					tripCount: totalTripCount,
					totalDistance: totalDistance,
					cargoWeight: totalCargoWeight,
					lateCount: totalLateCount,
					earlyLeaveCount: totalEarlyLeaveCount,
					warningCount: totalWarningCount,
					violationCount: totalViolationCount,
					overSpeedCount: totalOverSpeedCount,
					routeDeviationCount: totalRouteDeviationCount,
					performanceScore: driverResult.length > 0 ? totalPerformanceScore / driverResult.length : 0
				}
			}
		} catch (e) {
			console.error('加载行程统计失败', e)
		}
	}
	
	function loadUserInfo() {
		try {
			const stored = uni.getStorageSync('userInfo')
			if (stored) {
				userInfo.value = JSON.parse(stored) as UserInfo
			}
		} catch (e) {
			console.error('加载用户信息失败', e)
		}
	}
	
	function goToMessages() {
		uni.navigateTo({ url: '/pages/user/message/index' })
	}
	
	function goToCheckIn() {
		uni.navigateTo({ url: '/pages/user/attendance/index' })
	}
	
	function goToTripList() {
		uni.navigateTo({ url: '/pages/user/trip/index' })
	}
	
	function goToAttendanceList() {
		uni.navigateTo({ url: '/pages/user/attendance/index' })
	}
	
	function goToProfile() {
		uni.navigateTo({ url: '/pages/user/profile/index' })
	}
	
	onMounted(() => {
		loadUserInfo()
		if (userInfo.value?.id) {
			loadStatistics()
		}
	})
</script>

