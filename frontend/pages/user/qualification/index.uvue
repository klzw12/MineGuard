<template>
	<view class="page-container">
		<view class="header">
			<text class="title">资格认证</text>
		</view>
		
		<view class="content">
			<!-- 已实名认证状态 -->
			<view v-if="isVerified" class="verified-section">
				<view class="verified-card">
					<view class="verified-icon">✓</view>
					<text class="verified-title">实名认证已完成</text>
					<text class="verified-name">真实姓名：{{ verifiedRealName }}</text>
					
					<view class="id-card-preview">
						<view class="preview-item" v-if="idCardFrontUrl" @click="previewImage(idCardFrontUrl)">
							<image class="preview-image" :src="idCardFrontUrl" mode="aspectFit"></image>
							<text class="preview-label">身份证正面</text>
						</view>
						<view class="preview-item" v-if="idCardBackUrl" @click="previewImage(idCardBackUrl)">
							<image class="preview-image" :src="idCardBackUrl" mode="aspectFit"></image>
							<text class="preview-label">身份证背面</text>
						</view>
					</view>
				</view>
				
				<!-- 资格认证区域 -->
				<view class="cert-section">
					<view class="section-header">
						<text class="section-title">资格认证</text>
						<text class="section-desc">选择认证类型并上传相关证件</text>
					</view>
					
					<view class="form-group">
						<text class="label">认证类型 <text class="required">*</text></text>
						<view class="picker-wrapper" @click="showCertTypePicker = true">
							<text class="picker-value" :class="{ placeholder: !selectedCertType }">
								{{ selectedCertTypeName || '请选择认证类型' }}
							</text>
							<text class="picker-arrow">▼</text>
						</view>
					</view>
					
					<!-- 认证表单 -->
					<view v-if="selectedCertType" class="cert-form">
						<view class="form-group" v-if="selectedCertType === 'driver'">
							<text class="label">驾驶证 <text class="required">*</text></text>
							<view class="upload-area" @click="uploadCertImage('cert')">
								<image v-if="certPreview" class="preview-image" :src="certPreview" mode="aspectFit"></image>
								<view v-else class="upload-placeholder">
									<text class="upload-icon">📷</text>
									<text class="upload-text">点击上传驾驶证</text>
								</view>
							</view>
						</view>
						
						<view class="form-group" v-if="selectedCertType === 'safety_officer'">
							<text class="label">应急救援证 <text class="required">*</text></text>
							<view class="upload-area" @click="uploadCertImage('cert')">
								<image v-if="certPreview" class="preview-image" :src="certPreview" mode="aspectFit"></image>
								<view v-else class="upload-placeholder">
									<text class="upload-icon">📷</text>
									<text class="upload-text">点击上传应急救援证</text>
								</view>
							</view>
						</view>
						
						<view class="form-group" v-if="selectedCertType === 'repairman'">
							<text class="label">维修资格证 <text class="required">*</text></text>
							<view class="upload-area" @click="uploadCertImage('cert')">
								<image v-if="certPreview" class="preview-image" :src="certPreview" mode="aspectFit"></image>
								<view v-else class="upload-placeholder">
									<text class="upload-icon">📷</text>
									<text class="upload-text">点击上传维修资格证</text>
								</view>
							</view>
						</view>
						
						<view class="form-group">
							<text class="label">证书编号（可选）</text>
							<input class="input" v-model="certNumber" placeholder="请输入证书编号" />
						</view>
						
						<button class="submit-btn" @click="submitCert" :disabled="submitting">
							<text>{{ submitting ? '提交中...' : '提交认证' }}</text>
						</button>
					</view>
					
					<!-- 已认证列表 -->
					<view v-if="verifiedCerts.length > 0" class="verified-certs">
						<text class="certs-title">已获得资格</text>
						<view class="cert-item" v-for="(cert, index) in verifiedCerts" :key="index">
							<view class="cert-icon">✓</view>
							<view class="cert-info">
								<text class="cert-name">{{ cert.name }}</text>
								<text class="cert-status">已认证</text>
							</view>
						</view>
					</view>
				</view>
			</view>
			
			<!-- 未实名认证状态 -->
			<view v-else class="form-card">
				<view class="form-header">
					<text class="form-title">实名认证</text>
					<text class="form-desc">请上传身份证照片完成实名认证</text>
				</view>
				
				<view class="form-group">
					<text class="label">真实姓名 <text class="required">*</text></text>
					<input class="input" v-model="realName" placeholder="请输入真实姓名" />
				</view>
				
				<view class="form-group">
					<text class="label">身份证号 <text class="required">*</text></text>
					<input class="input" v-model="idCard" type="idcard" placeholder="请输入身份证号" maxlength="18" />
				</view>
				
				<view class="form-group">
					<text class="label">身份证正面 <text class="required">*</text></text>
					<view class="upload-area" @click="uploadFront">
						<image v-if="frontPreview" class="preview-image" :src="frontPreview" mode="aspectFit"></image>
						<view v-else class="upload-placeholder">
							<text class="upload-icon">📷</text>
							<text class="upload-text">点击上传身份证正面</text>
						</view>
					</view>
				</view>
				
				<view class="form-group">
					<text class="label">身份证背面（可选）</text>
					<view class="upload-area" @click="uploadBack">
						<image v-if="backPreview" class="preview-image" :src="backPreview" mode="aspectFit"></image>
						<view v-else class="upload-placeholder">
							<text class="upload-icon">📷</text>
							<text class="upload-text">点击上传身份证背面</text>
						</view>
					</view>
				</view>
				
				<button class="submit-btn" @click="submitAuth" :disabled="submitting">
					<text>{{ submitting ? '提交中...' : '提交实名认证' }}</text>
				</button>
			</view>
		</view>
		
		<!-- 认证类型选择器 -->
		<view class="picker-mask" v-if="showCertTypePicker" @click="showCertTypePicker = false">
			<view class="picker-content" @click.stop>
				<view class="picker-header">
					<text class="picker-title">选择认证类型</text>
					<text class="picker-close" @click="showCertTypePicker = false">×</text>
				</view>
				<view class="picker-options">
					<view 
						class="picker-option" 
						v-for="item in certTypeOptions" 
						:key="item.value"
						:class="{ selected: selectedCertType === item.value }"
						@click="selectCertType(item.value)"
					>
						<text class="option-text">{{ item.label }}</text>
						<text v-if="selectedCertType === item.value" class="option-check">✓</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, computed, onMounted } from 'vue'
	import { useUserStore } from '@/stores/user.uts'
	import { verifyIdCard, uploadDriverCert, uploadSafetyOfficerCert, uploadRepairmanCert } from '@/api/qualification.uts'
	import { getIdCardSignedUrls, getAllRoles, type IdCardVO } from '@/api/user.uts'
	import { toast } from '@/utils/toast.uts'
	import { imageToBase64 } from '@/utils/image.uts'
	import type { RoleVO } from '@/types/user.uts'
	
	const userStore = useUserStore()
	
	const isVerified = computed(() => !!userStore.userInfo.value?.realName)
	const verifiedRealName = computed(() => userStore.userInfo.value?.realName || '')
	
	const realName = ref('')
	const idCard = ref('')
	const frontPreview = ref('')
	const backPreview = ref('')
	const frontFilePath = ref('')
	const backFilePath = ref('')
	const submitting = ref(false)
	const idCardFrontUrl = ref('')
	const idCardBackUrl = ref('')
	
	const showCertTypePicker = ref(false)
	const selectedCertType = ref('')
	const certPreview = ref('')
	const certFilePath = ref('')
	const certNumber = ref('')
	const roleList = ref<RoleVO[]>([])
	
	const certTypeOptions = computed(() => {
		const options: { value: string, label: string }[] = []
		roleList.value.forEach((role: RoleVO) => {
			if (role.roleCode === 'ROLE_DRIVER') {
				options.push({ value: 'driver', label: role.roleName || '司机' })
			} else if (role.roleCode === 'ROLE_SAFETY_OFFICER') {
				options.push({ value: 'safety_officer', label: role.roleName || '安全员' })
			} else if (role.roleCode === 'ROLE_REPAIRMAN') {
				options.push({ value: 'repairman', label: role.roleName || '维修员' })
			}
		})
		if (options.length === 0) {
			options.push({ value: 'driver', label: '司机' })
			options.push({ value: 'safety_officer', label: '安全员' })
			options.push({ value: 'repairman', label: '维修员' })
		}
		return options
	})
	
	const selectedCertTypeName = computed(() => {
		const option = certTypeOptions.value.find((o: { value: string, label: string }) => o.value === selectedCertType.value)
		return option ? option.label : ''
	})
	
	const verifiedCerts = computed(() => {
		const certs: { name: string }[] = []
		const roleName = userStore.userInfo.value?.roleName
		if (roleName) {
			certs.push({ name: roleName })
		}
		return certs
	})
	
	onMounted(async () => {
		if (!userStore.userInfo.value) {
			userStore.loadFromStorage()
		}
		if (isVerified.value) {
			await loadIdCardUrls()
			await loadRoleList()
		}
	})
	
	async function loadIdCardUrls() {
		try {
			const data = await getIdCardSignedUrls()
			if (data) {
				idCardFrontUrl.value = data.frontUrl || ''
				idCardBackUrl.value = data.backUrl || ''
			}
		} catch (e) {
		}
	}
	
	async function loadRoleList() {
		try {
			const roles = await getAllRoles()
			if (roles && Array.isArray(roles)) {
				roleList.value = roles
			}
		} catch (e) {
		}
	}
	
	function previewImage(url: string | null | undefined) {
		if (!url) return
		
		uni.previewImage({
			urls: [url],
			current: url
		})
	}
	
	function uploadFront() {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					frontFilePath.value = tempFile
					frontPreview.value = tempFile
				}
			}
		})
	}
	
	function uploadBack() {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					backFilePath.value = tempFile
					backPreview.value = tempFile
				}
			}
		})
	}
	
	function uploadCertImage(type: string) {
		uni.chooseImage({
			count: 1,
			sizeType: ['compressed'],
			sourceType: ['album', 'camera'],
			success: (res) => {
				const tempFile = res.tempFilePaths[0]
				if (tempFile) {
					certFilePath.value = tempFile
					certPreview.value = tempFile
				}
			}
		})
	}
	
	function selectCertType(value: string) {
		selectedCertType.value = value
		certPreview.value = ''
		certFilePath.value = ''
		certNumber.value = ''
		showCertTypePicker.value = false
	}
	
	
	
	async function submitAuth() {
		if (!realName.value.trim()) {
			toast.error('请输入真实姓名')
			return
		}
		
		if (!idCard.value.trim() || idCard.value.length !== 18) {
			toast.error('请输入正确的身份证号')
			return
		}
		
		if (!frontFilePath.value) {
			toast.error('请上传身份证正面照片')
			return
		}
		
		let uid = userStore.userInfo.value?.id
		if (!uid) {
			userStore.loadFromStorage()
			uid = userStore.userInfo.value?.id
		}
		
		if (!uid) {
			toast.error('用户信息不存在，请重新登录')
			return
		}
		
		submitting.value = true
		
		try {
			const frontBase64 = await imageToBase64(frontFilePath.value)
			let backBase64 = ''
			if (backFilePath.value) {
				backBase64 = await imageToBase64(backFilePath.value)
			}
			
			const result = await verifyIdCard({
				userId: uid,
				realName: realName.value,
				idCard: idCard.value,
				idCardFrontBase64: frontBase64,
				idCardBackBase64: backBase64 || undefined
			}, { showLoading: true, showError: false })
			
			if (result === true) {
				toast.success('实名认证成功')
				await userStore.fetchCurrentUser()
				setTimeout(() => {
					loadIdCardUrls()
					loadRoleList()
				}, 500)
			} else {
				toast.error('实名认证失败，请重试')
			}
		} catch (e: any) {
			const errMsg = e?.message || '实名认证失败'
			toast.error(errMsg)
		} finally {
			submitting.value = false
		}
	}
	
	async function submitCert() {
		if (!selectedCertType.value) {
			toast.error('请选择认证类型')
			return
		}
		
		if (!certFilePath.value) {
			toast.error('请上传证书照片')
			return
		}
		
		let uid = userStore.userInfo.value?.id
		if (!uid) {
			userStore.loadFromStorage()
			uid = userStore.userInfo.value?.id
		}
		
		if (!uid) {
			toast.error('用户信息不存在，请重新登录')
			return
		}
		
		submitting.value = true
		toast.loading('提交中...')
		
		try {
			const certBase64 = await imageToBase64(certFilePath.value)
			
			const certData = {
				userId: uid,
				certNumber: certNumber.value || undefined,
				drivingLicenseBase64: undefined as string | undefined,
				emergencyCertBase64: undefined as string | undefined,
				repairCertBase64: undefined as string | undefined
			}
			
			if (selectedCertType.value === 'driver') {
				certData.drivingLicenseBase64 = certBase64
			} else if (selectedCertType.value === 'safety_officer') {
				certData.emergencyCertBase64 = certBase64
			} else if (selectedCertType.value === 'repairman') {
				certData.repairCertBase64 = certBase64
			}
			
			let result = null
if (selectedCertType.value === 'driver') {
	result = await uploadDriverCert(certData)
} else if (selectedCertType.value === 'safety_officer') {
	result = await uploadSafetyOfficerCert(certData)
} else if (selectedCertType.value === 'repairman') {
	result = await uploadRepairmanCert(certData)
}

if (result) {
	toast.success('资格认证提交成功')
	// 直接使用后端返回的 UserVO 更新本地缓存
	userStore.setUserInfo(result)
	certPreview.value = ''
	certFilePath.value = ''
	certNumber.value = ''
	selectedCertType.value = ''
}
		} catch (e: any) {
			toast.error(e?.message || '提交失败')
		} finally {
			submitting.value = false
		}
	}
</script>

<style>
