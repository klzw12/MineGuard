		padding: 32rpx;
	}
	
	.verified-section {
		display: flex;
		flex-direction: column;
		gap: 32rpx;
	}
	
	.verified-card {
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 48rpx 32rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.verified-icon {
		width: 120rpx;
		height: 120rpx;
		border-radius: 50%;
		background-color: #34C759;
		color: #FFFFFF;
		font-size: 64rpx;
		display: flex;
		justify-content: center;
		align-items: center;
		margin-bottom: 24rpx;
	}
	
	.verified-title {
		font-size: 36rpx;
		font-weight: 600;
		color: #1A1A1A;
		margin-bottom: 24rpx;
	}
	
	.verified-name, .verified-id {
		font-size: 28rpx;
		color: #666;
		margin-bottom: 12rpx;
	}
	
	.id-card-preview {
		display: flex;
		flex-direction: row;
		gap: 24rpx;
		margin-top: 32rpx;
		width: 100%;
	}
	
	.preview-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.preview-image {
		width: 100%;
		height: 240rpx;
		border-radius: 16rpx;
		background-color: #F7F8FA;
	}
	
	.preview-label {
		font-size: 24rpx;
		color: #8F959E;
		margin-top: 12rpx;
	}
	
	.cert-section {
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 32rpx;
	}
	
	.section-header {
		margin-bottom: 32rpx;
	}
	
	.section-title {
		font-size: 32rpx;
		font-weight: 600;
		color: #1A1A1A;
		display: block;
		margin-bottom: 8rpx;
	}
	
	.section-desc {
		font-size: 26rpx;
		color: #8F959E;
	}
	
	.form-card {
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 40rpx;
	}
	
	.form-header {
		margin-bottom: 48rpx;
	}
	
	.form-title {
		font-size: 36rpx;
		font-weight: 600;
		color: #1A1A1A;
		display: block;
		margin-bottom: 8rpx;
	}
	
	.form-desc {
		font-size: 26rpx;
		color: #8F959E;
		display: block;
	}
	
	.form-group {
		margin-bottom: 40rpx;
	}
	
	.label {
		font-size: 28rpx;
		font-weight: 500;
		color: #1A1A1A;
		display: block;
		margin-bottom: 16rpx;
	}
	
	.required {
		color: #FF3B30;
	}
	
	.input {
		width: 100%;
		height: 96rpx;
		background-color: #F7F8FA;
		border-radius: 20rpx;
		padding: 0 32rpx;
		font-size: 30rpx;
		color: #1A1A1A;
		box-sizing: border-box;
	}
	
	.picker-wrapper {
		width: 100%;
		height: 96rpx;
		background-color: #F7F8FA;
		border-radius: 20rpx;
		padding: 0 32rpx;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		box-sizing: border-box;
	}
	
	.picker-value {
		font-size: 30rpx;
		color: #1A1A1A;
	}
	
	.picker-value.placeholder {
		color: #8F959E;
	}
	
	.picker-arrow {
		font-size: 24rpx;
		color: #8F959E;
	}
	
	.cert-form {
		margin-top: 32rpx;
		padding-top: 32rpx;
		border-top: 2rpx solid #F0F2F5;
	}
	
	.upload-area {
		width: 100%;
		height: 320rpx;
		background-color: #F7F8FA;
		border-radius: 24rpx;
		border: 2rpx dashed #D1D5DB;
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
	}
	
	.upload-placeholder {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16rpx;
	}
	
	.upload-icon {
		font-size: 64rpx;
	}
	
	.upload-text {
		font-size: 26rpx;
		color: #8F959E;
	}
	
	.submit-btn {
		width: 100%;
		height: 96rpx;
		background: linear-gradient(135deg, #34C759 0%, #28a745 100%);
		border-radius: 20rpx;
		border: none;
		margin-top: 32rpx;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	
	.submit-btn[disabled] {
		opacity: 0.6;
	}
	
	.submit-btn text {
		font-size: 32rpx;
		font-weight: 600;
		color: #FFFFFF;
	}
	
	.verified-certs {
		margin-top: 32rpx;
		padding-top: 32rpx;
		border-top: 2rpx solid #F0F2F5;
	}
	
	.certs-title {
		font-size: 28rpx;
		font-weight: 500;
		color: #1A1A1A;
		margin-bottom: 24rpx;
		display: block;
	}
	
	.cert-item {
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 24rpx;
		background-color: #F7F8FA;
		border-radius: 16rpx;
		margin-bottom: 16rpx;
	}
	
	.cert-icon {
		width: 48rpx;
		height: 48rpx;
		border-radius: 50%;
		background-color: #34C759;
		color: #FFFFFF;
		font-size: 28rpx;
		display: flex;
		justify-content: center;
		align-items: center;
		margin-right: 24rpx;
	}
	
	.cert-info {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	
	.cert-name {
		font-size: 28rpx;
		font-weight: 500;
		color: #1A1A1A;
	}
	
	.cert-status {
		font-size: 24rpx;
		color: #34C759;
		margin-top: 4rpx;
	}
	
	.picker-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		display: flex;
		justify-content: center;
		align-items: flex-end;
		z-index: 999;
	}
	
	.picker-content {
		width: 100%;
