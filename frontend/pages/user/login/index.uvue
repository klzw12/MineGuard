<template>
	<view class="login-container user-login">
		<view class="logo-section">
			<image class="logo" src="/static/logo/logo.png"></image>
			<text class="app-name">MineGuard</text>
			<text class="slogan">用户端登录</text>
		</view>
		
		<view class="form-section">
			<view class="form-item">
				<text class="label">司机账号</text>
				<input class="input" type="text" v-model="username" placeholder="请输入司机账号" placeholder-style="color: #999" />
			</view>
			
			<view class="form-item">
				<text class="label">密码</text>
				<input class="input" type="password" v-model="password" placeholder="请输入密码" placeholder-style="color: #999" />
			</view>
			
			<button class="login-btn" @click="handleLogin">登录</button>
			
			<view class="role-switch">
				<text class="switch-text">是管理员？</text>
				<navigator url="/pages/admin/login/index" class="switch-link">切换到管理端</navigator>
			</view>
		</view>
		
		<view class="footer">
			<text class="copyright">© 2026 MineGuard. 保留所有权利</text>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'
	
	const username = ref('')
	const password = ref('')
	
	function handleLogin() {
		if (!username.value || !password.value) {
			uni.showToast({
				title: '请输入账号和密码',
				icon: 'none',
				position: 'bottom'
			})
			return
		}
		
		// 模拟用户端登录成功
		uni.showToast({
			title: '登录成功',
			icon: 'success',
			position: 'bottom'
		})
		
		// 存储登录状态和角色信息
		uni.setStorageSync('loginStatus', true)
		uni.setStorageSync('userRole', 'user')
		uni.setStorageSync('username', username.value)
		
		// 跳转到用户端首页
		setTimeout(() => {
			uni.switchTab({
				url: '/pages/user/home/index'
			})
		}, 1000)
	}
</script>

<style>
