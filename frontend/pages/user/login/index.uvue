		margin-bottom: 30rpx;
	}
	
	.label {
		display: block;
		font-size: 24rpx;
		color: #333;
		margin-bottom: 10rpx;
	}
	
	.input {
		width: 100%;
		height: 80rpx;
		background-color: #fff;
		border-radius: 10rpx;
		padding: 0 30rpx;
		box-sizing: border-box;
		font-size: 28rpx;
		border: 1rpx solid #e5e5e5;
	}
	
	.login-btn {
		width: 100%;
		height: 88rpx;
		background: linear-gradient(135deg, #34C759 0%, #28a745 100%);
		color: #fff;
		font-size: 32rpx;
		font-weight: bold;
		border-radius: 10rpx;
		margin-top: 50rpx;
		margin-bottom: 30rpx;
	}
	
	.role-switch {
		display: flex;
		justify-content: center;
		align-items: center;
