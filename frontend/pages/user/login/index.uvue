		display: flex;
		flex-direction: column;
		min-height: 100vh;
		padding: 80rpx 40rpx 40rpx;
		box-sizing: border-box;
		background-color: #f5f5f5;
	}
	
	.user-login {
		background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
	}
	
	.logo-section {
		display: flex;
