	}
	
	.attendance-card {
		background-color: #fff;
		border-radius: 24rpx;
		padding: 32rpx;
		box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
	}
	
	.attendance-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 24rpx;
	}
	
	.attendance-title {
		font-size: 32rpx;
		font-weight: 600;
		color: #2c3e50;
	}
	
	.attendance-date {
		font-size: 26rpx;
		color: #8F959E;
	}
	
	.attendance-status {
		margin-bottom: 24rpx;
	}
	
	.status-row {
		display: flex;
		flex-direction: row;
		gap: 32rpx;
		margin-bottom: 16rpx;
	}
	
	.status-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 8rpx;
	}
	
	.status-label {
		font-size: 24rpx;
		color: #8F959E;
	}
	
	.status-value {
		font-size: 32rpx;
		font-weight: 600;
	}
	
	.status-value.success {
		color: #34C759;
	}
	
	.status-value.pending {
		color: #FF9500;
	}
	
	.status-badge {
		display: inline-flex;
		padding: 8rpx 24rpx;
		border-radius: 24rpx;
		align-self: flex-start;
	}
	
	.status-badge text {
		font-size: 24rpx;
		font-weight: 500;
	}
	
	.status-badge.normal {
		background-color: #F0FFF4;
	}
	
