		margin-bottom: 32rpx;
	}
	
	.empty-text {
		font-size: 32rpx;
		font-weight: 500;
		color: #2c3e50;
		margin-bottom: 16rpx;
	}
	
	.empty-desc {
		font-size: 28rpx;
		color: #8F959E;
	}
</style>
