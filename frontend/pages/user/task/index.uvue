		color: #FF3B30;
	}
	
	.status-badge.pending {
		background-color: #F7F8FA;
	}
	
	.status-badge.pending text {
		color: #8F959E;
	}
	
	.attendance-actions {
		display: flex;
		flex-direction: row;
		gap: 24rpx;
	}
	
	.check-btn {
		flex: 1;
		height: 88rpx;
		background: linear-gradient(135deg, #34C759 0%, #28a745 100%);
		border-radius: 20rpx;
		display: flex;
		justify-content: center;
		align-items: center;
		border: none;
	}
	
	.check-btn.check-out {
		background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
	}
	
	.check-btn.disabled {
		background: #C7C7CC;
	}
	
	.check-btn text {
		font-size: 28rpx;
		font-weight: 600;
		color: #fff;
	}
	
	.tab-scroll {
		background-color: #fff;
		margin-bottom: 24rpx;
	}
	
	.tab-list {
		display: flex;
		flex-direction: row;
		padding: 0 32rpx;
		gap: 48rpx;
	}
	
	.tab-item {
		padding: 24rpx 0;
		font-size: 28rpx;
		color: #8F959E;
		position: relative;
		white-space: nowrap;
	}
	
	.tab-item.active {
		color: #2c3e50;
		font-weight: 500;
	}
	
	.tab-item.active::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 40rpx;
		height: 6rpx;
		background-color: #34C759;
		border-radius: 4rpx;
	}
	
	.content-area {
		flex: 1;
		padding: 0 30rpx 30rpx;
	}
	
	.task-card {
		background-color: #fff;
		border-radius: 20rpx;
		padding: 30rpx;
		margin-bottom: 24rpx;
		box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
	}
	
	.task-header {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 16rpx;
	}
	
	.task-info {
		display: flex;
		flex-direction: column;
		gap: 8rpx;
		flex: 1;
	}
	
	.task-title {
		font-size: 32rpx;
		font-weight: 500;
		color: #2c3e50;
	}
	
	.task-time {
		font-size: 24rpx;
		color: #8F959E;
	}
	
	.task-card .status-badge {
		padding: 8rpx 24rpx;
		border-radius: 24rpx;
	}
	
	.task-card .status-badge.pending {
		background-color: #FFF7E6;
	}
	
	.task-card .status-badge.pending text {
		color: #FF9500;
	}
	
	.task-card .status-badge.inProgress {
		background-color: #E6F4FF;
	}
	
	.task-card .status-badge.inProgress text {
		color: #007AFF;
	}
	
	.task-card .status-badge.completed {
		background-color: #F0FFF4;
	}
	
	.task-card .status-badge.completed text {
		color: #34C759;
	}
	
	.task-desc {
		margin-bottom: 24rpx;
	}
	
	.task-desc text {
		font-size: 26rpx;
		color: #5A5F6B;
		line-height: 1.6;
	}
	
	.task-footer {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding-top: 24rpx;
		border-top: 2rpx solid #F0F2F5;
	}
	
	.task-location {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 8rpx;
	}
	
	.icon {
		font-size: 28rpx;
	}
	
	.location-text {
