		border-radius: 16rpx;
		padding: 0 24rpx;
		font-size: 28rpx;
	}
	
	.form-textarea {
		width: 100%;
		min-height: 200rpx;
		background-color: #f5f5f5;
		border-radius: 16rpx;
		padding: 24rpx;
		font-size: 28rpx;
		box-sizing: border-box;
	}
	
	.char-count {
		font-size: 24rpx;
		color: #999;
		text-align: right;
		display: block;
		margin-top: 8rpx;
	}
	
	.upload-area {
		height: 200rpx;
		background-color: #f5f5f5;
		border-radius: 16rpx;
		border: 2rpx dashed #ddd;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	
	.upload-placeholder {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.upload-icon {
		font-size: 64rpx;
		margin-bottom: 16rpx;
	}
	
