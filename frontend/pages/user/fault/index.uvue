		background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
		border-radius: 16rpx;
		display: flex;
		justify-content: center;
		align-items: center;
		border: none;
		margin-top: 16rpx;
	}
	
	.submit-btn text {
		font-size: 30rpx;
		font-weight: 500;
		color: #fff;
	}
	
	.history-section {
		background-color: #fff;
		border-radius: 24rpx;
		padding: 32rpx;
	}
	
	.section-title {
		font-size: 30rpx;
		font-weight: bold;
		color: #333;
		display: block;
		margin-bottom: 24rpx;
	}
	
	.history-list {
		display: flex;
		flex-direction: column;
		gap: 24rpx;
	}
	
	.history-item {
		background-color: #f9f9f9;
		border-radius: 16rpx;
		padding: 24rpx;
	}
	
	.history-header {
		display: flex;
