<template>
	<view class="fault-container">
		<view class="fault-header">
			<text class="header-title">故障申报</text>
		</view>
		
		<view class="fault-content">
			<view class="form-card">
				<view class="form-group">
					<text class="form-label">故障类型</text>
					<picker :value="faultTypeIndex" :range="faultTypes" @change="onFaultTypeChange">
						<view class="picker-input">
							<text>{{ faultTypes[faultTypeIndex] }}</text>
							<text class="picker-arrow">▼</text>
						</view>
					</picker>
				</view>
				
				<view class="form-group">
					<text class="form-label">车辆编号</text>
					<input class="form-input" v-model="vehicleNo" placeholder="请输入车辆编号" />
				</view>
				
				<view class="form-group">
					<text class="form-label">故障描述</text>
					<textarea class="form-textarea" v-model="description" placeholder="请详细描述故障情况" :maxlength="500" />
					<text class="char-count">{{ description.length }}/500</text>
				</view>
				
				<view class="form-group">
					<text class="form-label">故障照片</text>
					<view class="upload-area" @click="uploadPhoto">
						<view class="upload-placeholder">
							<text class="upload-icon">📷</text>
							<text class="upload-text">点击上传照片</text>
						</view>
					</view>
				</view>
				
				<button class="submit-btn" @click="submitFault">
					<text>提交申报</text>
				</button>
			</view>
			
			<view class="history-section">
				<text class="section-title">历史申报</text>
				<view class="history-list">
					<view class="history-item" v-for="(item, index) in historyList" :key="index">
						<view class="history-header">
							<text class="history-type">{{ item.type }}</text>
							<text class="history-status" :class="'status-' + item.status">{{ item.statusText }}</text>
						</view>
						<text class="history-desc">{{ item.description }}</text>
						<text class="history-time">{{ item.time }}</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'
	
	const faultTypes = ['发动机故障', '制动系统', '轮胎问题', '电气系统', '其他']
	const faultTypeIndex = ref(0)
	const vehicleNo = ref('')
	const description = ref('')
	
	const historyList = ref([
		{
			type: '发动机故障',
			description: '发动机启动困难，需要多次尝试',
			status: 2,
			statusText: '已处理',
			time: '2026-03-15 14:30'
		},
		{
			type: '轮胎问题',
			description: '左前轮胎磨损严重，需要更换',
			status: 1,
			statusText: '处理中',
			time: '2026-03-18 09:15'
		}
	])
	
	const onFaultTypeChange = (e: any) => {
		faultTypeIndex.value = e.detail.value
	}
	
	const uploadPhoto = () => {
		uni.chooseImage({
			count: 1,
			success: (res) => {
				uni.showToast({
					title: '照片已选择',
					icon: 'success'
				})
			}
		})
	}
	
	const submitFault = () => {
		if (!vehicleNo.value.trim()) {
			uni.showToast({
				title: '请输入车辆编号',
				icon: 'none'
			})
			return
		}
		if (!description.value.trim()) {
			uni.showToast({
				title: '请描述故障情况',
				icon: 'none'
			})
			return
		}
		
		uni.showToast({
			title: '申报提交成功',
			icon: 'success'
		})
		
		vehicleNo.value = ''
		description.value = ''
		faultTypeIndex.value = 0
	}
</script>

<style>
	.fault-container {
		min-height: 100vh;
		background-color: #f5f5f5;
	}
	
