<template>
  <view class="appeal-page">
    <view class="appeal-container">
      <view class="appeal-header">
        <text class="appeal-title">账号申诉</text>
        <text class="appeal-subtitle">如果您的账号被误禁用，可以提交申诉申请</text>
      </view>

      <view class="appeal-form" v-if="!hasPending">
        <view class="form-item">
          <text class="form-label">申诉原因</text>
          <textarea
            class="form-textarea"
            v-model="appealReason"
            placeholder="请详细说明申诉原因"
            :maxlength="500"
          />
          <text class="char-count">{{ appealReason.length }}/500</text>
        </view>

        <button class="submit-btn" @click="submitAppeal" :disabled="loading">
          {{ loading ? '提交中...' : '提交申诉' }}
        </button>
      </view>

      <view class="pending-tip" v-else>
        <view class="tip-icon">⏳</view>
        <text class="tip-text">您有待处理的申诉，请耐心等待管理员审核</text>
      </view>

      <view class="appeal-history">
        <text class="history-title">申诉记录</text>
        <view class="history-list" v-if="appeals.length > 0">
          <view class="history-item" v-for="item in appeals" :key="item.id">
            <view class="history-header">
              <text class="history-status" :class="'status-' + item.status">
                {{ item.statusLabel }}
              </text>
              <text class="history-time">{{ formatTime(item.createTime) }}</text>
            </view>
            <view class="history-content">
              <text class="history-reason">{{ item.appealReason }}</text>
              <view class="history-opinion" v-if="item.adminOpinion">
                <text class="opinion-label">处理意见：</text>
                <text class="opinion-text">{{ item.adminOpinion }}</text>
              </view>
              <view class="history-handler" v-if="item.handlerName">
                <text>处理人：{{ item.handlerName }}</text>
                <text v-if="item.handleTime">处理时间：{{ formatTime(item.handleTime) }}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" v-else>
          <text>暂无申诉记录</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="ts">
import { ref, onMounted } from 'vue'
import { createAppeal, getMyAppeals, hasPendingAppeal } from '@/api/user.uts'
import type { UserAppealVO } from '@/types/user.uts'

const appealReason = ref('')
const loading = ref(false)
const hasPending = ref(false)
const appeals = ref<UserAppealVO[]>([])

onMounted(() => {
  checkPendingAppeal()
  loadAppeals()
})

const checkPendingAppeal = () => {
  hasPendingAppeal().then((res) => {
    hasPending.value = res
  })
}

const loadAppeals = () => {
  getMyAppeals().then((res) => {
    appeals.value = res
  })
}

const submitAppeal = () => {
  if (!appealReason.value.trim()) {
    uni.showToast({
      title: '请填写申诉原因',
      icon: 'none'
    })
    return
  }

  loading.value = true
  createAppeal({ appealReason: appealReason.value })
    .then(() => {
      uni.showToast({
        title: '申诉提交成功',
        icon: 'success'
      })
      appealReason.value = ''
      hasPending.value = true
      loadAppeals()
    })
    .catch((err) => {
      uni.showToast({
        title: err.message || '提交失败',
        icon: 'none'
      })
    })
    .finally(() => {
      loading.value = false
    })
}

const formatTime = (time: string) => {
  return time.substring(0, 19).replace('T', ' ')
}
</script>

