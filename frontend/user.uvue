		--user-success-color: #34C759;
		--user-warning-color: #FF9500;
		--user-error-color: #FF3B30;
		--user-info-color: #5AC8FA;
		
		/* 阴影 */
		--user-shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
		--user-shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
		--user-shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.16);
		
		/* 圆角 */
		--user-radius-sm: 4rpx;
		--user-radius-md: 8rpx;
		--user-radius-lg: 16rpx;
		--user-radius-xl: 24rpx;
		
		/* 间距 */
		--user-space-xs: 8rpx;
		--user-space-sm: 16rpx;
		--user-space-md: 24rpx;
		--user-space-lg: 32rpx;
		--user-space-xl: 48rpx;
		
		/* 字体大小 */
		--user-font-xs: 20rpx;
		--user-font-sm: 24rpx;
