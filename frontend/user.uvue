<template>
	<view class="user-app-container">
		<view v-if="!loginStatus" class="loading-container">
			<text class="loading-text">加载中...</text>
		</view>
	</view>
</template>

<script lang="uts">
	// #ifdef APP-ANDROID || APP-HARMONY
	let firstBackTime = 0
	// #endif
	export default {
		data() {
			return {
				loginStatus: false
			}
		},
		onLaunch() {
			console.log('User App Launch')
			this.checkLoginStatus()
		},
		onShow() {
			console.log('User App Show')
		},
		onHide() {
			console.log('User App Hide')
		},
		// #ifdef APP-ANDROID || APP-HARMONY
		onLastPageBackPress() {
			console.log('User App LastPageBackPress')
			if (firstBackTime == 0) {
				uni.showToast({
					title: '再按一次退出应用',
					position: 'bottom',
				})
				firstBackTime = Date.now()
				setTimeout(() => {
					firstBackTime = 0
				}, 2000)
			} else if (Date.now() - firstBackTime < 2000) {
				firstBackTime = Date.now()
				uni.exit()
			}
		},
		// #endif
		onExit() {
			console.log('User App Exit')
		},
		methods: {
			checkLoginStatus() {
				// 检查用户端登录状态
				const loginStatus = uni.getStorageSync('loginStatus')
				const userRole = uni.getStorageSync('userRole')
				
				if (loginStatus && userRole === 'user') {
					// 已登录用户端，跳转到用户端首页
					this.loginStatus = true
					uni.switchTab({
						url: '/pages/user/home/index'
					})
				} else {
					// 未登录或角色不正确，跳转到用户端登录页
					this.loginStatus = false
					uni.redirectTo({
						url: '/pages/user/login/index'
					})
				}
			}
		}
	}
</script>

<style>
	/* 用户端全局样式 */
