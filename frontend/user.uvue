	}
	
	.loading-text {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: bold;
	}
	
	/* 用户端主题变量 */
	:root {
		/* 主色调 */
		--user-primary-color: #34C759;
		--user-secondary-color: #28a745;
		--user-accent-color: #1e7e34;
		
		/* 背景色 */
		--user-bg-color: #FFFFFF;
		--user-bg-secondary: #F5F7FA;
		--user-bg-tertiary: #E9EEF5;
		
		/* 文字色 */
		--user-text-primary: #333333;
